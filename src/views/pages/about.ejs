<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <%- include('../partials/head', { seo: seo || {}, settings: settings, isAdmin: false }) %>
</head>
<body class="min-h-screen bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">

  <%- include('../partials/navbar', { settings: settings, currentPath: currentPath || '' }) %>

  <main id="main-content">

    <%# ── Page Header ────────────────────────────────────────────────────────── %>
    <section class="bg-zinc-950 py-16 sm:py-20" aria-label="Page header">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-3xl font-bold text-white sm:text-4xl">Tentang Saya</h1>
          <p class="mt-3 text-zinc-400">Web Developer & SEO Specialist</p>
        </div>
      </div>
    </section>

    <%# ── About Content ──────────────────────────────────────────────────────── %>
    <section class="py-16 sm:py-20" aria-labelledby="about-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16">

          <%# About text from Quill rich text editor %>
          <div>
            <h2 id="about-heading" class="mb-6 text-2xl font-bold text-zinc-900 dark:text-white md:text-3xl">
              Halo, Saya Angga
            </h2>
            <% const aboutContent = (settings && settings.about_content) ? settings.about_content : null; %>
            <% if (aboutContent) { %>
            <div class="prose prose-zinc max-w-none dark:prose-invert">
              <%- aboutContent %>
            </div>
            <% } else { %>
            <p class="text-zinc-500 dark:text-zinc-400">
              Konten about belum dikonfigurasi. Silakan update melalui admin panel.
            </p>
            <% } %>

            <%# Social Links %>
            <% if (socialLinks && socialLinks.length > 0) { %>
            <div class="mt-8">
              <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
                Temukan Saya Di
              </h3>
              <ul class="flex flex-wrap gap-3" role="list">
                <% socialLinks.forEach(function(link) { %>
                <li>
                  <a
                    href="<%= link.url %>"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="<%= link.platform %>"
                    class="flex h-11 w-11 items-center justify-center rounded-lg border border-zinc-200 text-zinc-500 transition-colors hover:border-cyan-500 hover:text-cyan-500 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-cyan-400 dark:hover:text-cyan-400"
                  >
                    <% if (link.icon) { %>
                    <i class="<%= link.icon %>" aria-hidden="true"></i>
                    <% } else { %>
                    <span class="text-xs font-semibold"><%= link.platform.charAt(0).toUpperCase() %></span>
                    <% } %>
                  </a>
                </li>
                <% }); %>
              </ul>
            </div>
            <% } %>
          </div>

          <%# Skills %>
          <div>
            <h2 class="mb-6 text-2xl font-bold text-zinc-900 dark:text-white md:text-3xl">
              Keahlian
            </h2>
            <% if (skills && skills.length > 0) { %>
            <div class="space-y-5">
              <% skills.forEach(function(skill) { %>
              <div>
                <div class="mb-1 flex items-center justify-between">
                  <span class="text-sm font-medium text-zinc-700 dark:text-zinc-300">
                    <%= skill.name %>
                  </span>
                  <span class="text-sm font-semibold text-cyan-500 dark:text-cyan-400">
                    <%= skill.level %>%
                  </span>
                </div>
                <div
                  class="h-2 w-full overflow-hidden rounded-full bg-zinc-200 dark:bg-zinc-700"
                  role="progressbar"
                  aria-valuenow="<%= skill.level %>"
                  aria-valuemin="0"
                  aria-valuemax="100"
                  aria-label="<%= skill.name %> skill level"
                >
                  <div
                    class="skill-progress h-full rounded-full bg-cyan-500 transition-all duration-700"
                    style="width: <%= skill.level %>%"
                  ></div>
                </div>
              </div>
              <% }); %>
            </div>
            <% } else { %>
            <p class="text-zinc-500 dark:text-zinc-400">Belum ada data keahlian.</p>
            <% } %>
          </div>

        </div>
      </div>
    </section>

    <%# ── Experience Timeline ────────────────────────────────────────────────── %>
    <% if (experiences && experiences.length > 0) { %>
    <section class="bg-zinc-50 py-16 dark:bg-zinc-900 sm:py-20" aria-labelledby="experience-heading">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">

        <div class="mb-12 text-center">
          <h2 id="experience-heading" class="text-2xl font-bold text-zinc-900 dark:text-white md:text-3xl">
            Pengalaman Kerja
          </h2>
        </div>

        <ol class="relative border-l border-zinc-300 dark:border-zinc-700" aria-label="Riwayat pengalaman kerja">
          <% experiences.forEach(function(exp) { %>
          <li class="mb-10 ml-6">
            <span class="absolute -left-3 flex h-6 w-6 items-center justify-center rounded-full bg-cyan-500 ring-4 ring-white dark:ring-zinc-900" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </span>
            <article>
              <h3 class="mb-1 text-lg font-semibold text-zinc-900 dark:text-white">
                <%= exp.position %>
              </h3>
              <p class="mb-1 font-medium text-cyan-500 dark:text-cyan-400">
                <%= exp.company_name %>
              </p>
              <time class="mb-3 block text-sm text-zinc-500 dark:text-zinc-400">
                <%
                  const startDate = new Date(exp.start_date);
                  const startStr = startDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'long' });
                  let endStr = 'Sekarang';
                  if (!exp.is_current && exp.end_date) {
                    endStr = new Date(exp.end_date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long' });
                  }
                %>
                <%= startStr %> — <%= endStr %>
                <% if (exp.is_current) { %>
                <span class="ml-2 inline-block rounded-full bg-cyan-50 px-2 py-0.5 text-xs font-medium text-cyan-600 dark:bg-cyan-900/30 dark:text-cyan-400">
                  Saat ini
                </span>
                <% } %>
              </time>
              <% if (exp.description) { %>
              <p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                <%= exp.description %>
              </p>
              <% } %>
            </article>
          </li>
          <% }); %>
        </ol>

      </div>
    </section>
    <% } %>

  </main>

  <%- include('../partials/footer', { settings: settings, socialLinks: socialLinks || [] }) %>
  <%- include('../partials/scripts') %>
</body>
</html>
