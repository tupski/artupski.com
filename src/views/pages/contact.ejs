<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <%- include('../partials/head', { seo: seo || {}, settings: settings, isAdmin: false }) %>
</head>
<body class="min-h-screen bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">

  <%- include('../partials/navbar', { settings: settings, currentPath: currentPath || '' }) %>

  <main id="main-content">

    <%# ── Page Header ────────────────────────────────────────────────────────── %>
    <section class="bg-zinc-950 py-16 sm:py-20" aria-label="Page header">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-3xl font-bold text-white sm:text-4xl">Hubungi Saya</h1>
          <p class="mt-3 text-zinc-400">Ada pertanyaan atau proyek? Mari berdiskusi</p>
        </div>
      </div>
    </section>

    <%# ── Contact Section ────────────────────────────────────────────────────── %>
    <section class="py-16 sm:py-20" aria-labelledby="contact-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <h2 id="contact-heading" class="sr-only">Form kontak dan informasi kontak</h2>

        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16">

          <%# ── Contact Info ──────────────────────────────────────────────────── %>
          <div>
            <h3 class="mb-6 text-xl font-bold text-zinc-900 dark:text-white">
              Informasi Kontak
            </h3>

            <ul class="space-y-5" role="list">

              <% const contactEmail = (settings && settings.contact_email) ? settings.contact_email : null; %>
              <% if (contactEmail) { %>
              <li class="flex items-start gap-4">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-cyan-50 dark:bg-cyan-900/30" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Email</p>
                  <a href="mailto:<%= contactEmail %>" class="font-medium text-zinc-900 transition-colors hover:text-cyan-500 dark:text-white dark:hover:text-cyan-400">
                    <%= contactEmail %>
                  </a>
                </div>
              </li>
              <% } %>

              <% const whatsapp = (settings && settings.whatsapp_number) ? settings.whatsapp_number : null; %>
              <% if (whatsapp) { %>
              <li class="flex items-start gap-4">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-cyan-50 dark:bg-cyan-900/30" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-zinc-500 dark:text-zinc-400">WhatsApp</p>
                  <a href="https://wa.me/<%= whatsapp.replace(/\D/g, '') %>" target="_blank" rel="noopener noreferrer" class="font-medium text-zinc-900 transition-colors hover:text-cyan-500 dark:text-white dark:hover:text-cyan-400">
                    <%= whatsapp %>
                  </a>
                </div>
              </li>
              <% } %>

              <% const address = (settings && settings.address) ? settings.address : null; %>
              <% if (address) { %>
              <li class="flex items-start gap-4">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-cyan-50 dark:bg-cyan-900/30" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Alamat</p>
                  <p class="font-medium text-zinc-900 dark:text-white"><%= address %></p>
                </div>
              </li>
              <% } %>

            </ul>
          </div>

          <%# ── Contact Form ──────────────────────────────────────────────────── %>
          <div>

            <%# Success Message %>
            <% if (success) { %>
            <div class="mb-6 rounded-xl border border-green-200 bg-green-50 p-5 dark:border-green-900/50 dark:bg-green-900/20" role="alert">
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <p class="font-semibold text-green-800 dark:text-green-300">Pesan Terkirim!</p>
                  <p class="mt-1 text-sm text-green-700 dark:text-green-400">
                    Terima kasih telah menghubungi saya. Saya akan membalas pesan Anda secepatnya.
                  </p>
                </div>
              </div>
            </div>
            <% } %>

            <%# General Error %>
            <% if (errors && errors.general) { %>
            <div class="mb-6 rounded-xl border border-red-200 bg-red-50 p-4 dark:border-red-900/50 dark:bg-red-900/20" role="alert">
              <p class="text-sm text-red-700 dark:text-red-400"><%= errors.general %></p>
            </div>
            <% } %>

            <form
              action="/contact"
              method="POST"
              novalidate
              aria-label="Form kontak"
            >

              <%# Name %>
              <div class="mb-5">
                <label for="name" class="mb-1.5 block text-sm font-medium text-zinc-700 dark:text-zinc-300">
                  Nama <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  value="<%= (formData && formData.name) ? formData.name : '' %>"
                  required
                  maxlength="100"
                  autocomplete="name"
                  aria-required="true"
                  aria-describedby="<%= (errors && errors.name) ? 'name-error' : '' %>"
                  class="w-full rounded-lg border px-4 py-3 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500
                    <%= (errors && errors.name) ? 'border-red-400 bg-red-50 dark:border-red-600 dark:bg-red-900/10' : 'border-zinc-300 bg-white dark:border-zinc-700 dark:bg-zinc-900' %>
                    text-zinc-900 placeholder-zinc-400 dark:text-white dark:placeholder-zinc-500"
                  placeholder="Nama lengkap Anda"
                />
                <% if (errors && errors.name) { %>
                <p id="name-error" class="mt-1.5 text-xs text-red-600 dark:text-red-400" role="alert">
                  <%= errors.name %>
                </p>
                <% } %>
              </div>

              <%# Email %>
              <div class="mb-5">
                <label for="email" class="mb-1.5 block text-sm font-medium text-zinc-700 dark:text-zinc-300">
                  Email <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  value="<%= (formData && formData.email) ? formData.email : '' %>"
                  required
                  maxlength="254"
                  autocomplete="email"
                  aria-required="true"
                  aria-describedby="<%= (errors && errors.email) ? 'email-error' : '' %>"
                  class="w-full rounded-lg border px-4 py-3 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500
                    <%= (errors && errors.email) ? 'border-red-400 bg-red-50 dark:border-red-600 dark:bg-red-900/10' : 'border-zinc-300 bg-white dark:border-zinc-700 dark:bg-zinc-900' %>
                    text-zinc-900 placeholder-zinc-400 dark:text-white dark:placeholder-zinc-500"
                  placeholder="email@contoh.com"
                />
                <% if (errors && errors.email) { %>
                <p id="email-error" class="mt-1.5 text-xs text-red-600 dark:text-red-400" role="alert">
                  <%= errors.email %>
                </p>
                <% } %>
              </div>

              <%# Subject %>
              <div class="mb-5">
                <label for="subject" class="mb-1.5 block text-sm font-medium text-zinc-700 dark:text-zinc-300">
                  Subjek <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="subject"
                  name="subject"
                  value="<%= (formData && formData.subject) ? formData.subject : '' %>"
                  required
                  maxlength="150"
                  aria-required="true"
                  aria-describedby="<%= (errors && errors.subject) ? 'subject-error' : '' %>"
                  class="w-full rounded-lg border px-4 py-3 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500
                    <%= (errors && errors.subject) ? 'border-red-400 bg-red-50 dark:border-red-600 dark:bg-red-900/10' : 'border-zinc-300 bg-white dark:border-zinc-700 dark:bg-zinc-900' %>
                    text-zinc-900 placeholder-zinc-400 dark:text-white dark:placeholder-zinc-500"
                  placeholder="Topik pesan Anda"
                />
                <% if (errors && errors.subject) { %>
                <p id="subject-error" class="mt-1.5 text-xs text-red-600 dark:text-red-400" role="alert">
                  <%= errors.subject %>
                </p>
                <% } %>
              </div>

              <%# Message %>
              <div class="mb-6">
                <label for="message" class="mb-1.5 block text-sm font-medium text-zinc-700 dark:text-zinc-300">
                  Pesan <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  maxlength="2000"
                  aria-required="true"
                  aria-describedby="<%= (errors && errors.message) ? 'message-error' : '' %>"
                  class="w-full resize-y rounded-lg border px-4 py-3 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500
                    <%= (errors && errors.message) ? 'border-red-400 bg-red-50 dark:border-red-600 dark:bg-red-900/10' : 'border-zinc-300 bg-white dark:border-zinc-700 dark:bg-zinc-900' %>
                    text-zinc-900 placeholder-zinc-400 dark:text-white dark:placeholder-zinc-500"
                  placeholder="Tuliskan pesan Anda di sini..."
                ><%= (formData && formData.message) ? formData.message : '' %></textarea>
                <% if (errors && errors.message) { %>
                <p id="message-error" class="mt-1.5 text-xs text-red-600 dark:text-red-400" role="alert">
                  <%= errors.message %>
                </p>
                <% } %>
              </div>

              <button
                type="submit"
                class="w-full rounded-lg bg-cyan-500 px-6 py-3 text-base font-semibold text-white shadow-md transition-colors hover:bg-cyan-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400 sm:w-auto"
              >
                Kirim Pesan
              </button>

            </form>
          </div>

        </div>
      </div>
    </section>

  </main>

  <%- include('../partials/footer', { settings: settings, socialLinks: [] }) %>
  <%- include('../partials/scripts') %>
</body>
</html>
