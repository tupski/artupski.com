{
  "name": "artupski-portfolio-cms",
  "version": "1.0.0",
  "description": "Website portfolio personal CMS dinamis untuk Angga Dwy Saputra — Web Developer & SEO Specialist",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "test": "jest --runInBand",
    "test:unit": "jest tests/utils tests/models tests/middlewares --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "build:css": "tailwindcss -i src/public/css/app.css -o src/public/css/output.css --minify"
  },
  "keywords": [
    "portfolio",
    "cms",
    "express",
    "nodejs",
    "supabase"
  ],
  "author": "Angga Dwy Saputra",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.5.0",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.13.3",
    "sharp": "^0.33.5",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.0",
    "tailwindcss": "^3.4.17"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/public/**"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "src/"
    ],
    "ext": "js,ejs,json",
    "ignore": [
      "src/public/",
      "tests/"
    ]
  }
}
