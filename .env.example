# Server Configuration
PORT=3000

# Session Secret — gunakan string acak yang panjang dan aman
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-this-to-a-very-long-random-secret-string

# Database URL (PostgreSQL connection string dari Supabase)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Supabase Configuration
# Dapatkan dari: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Admin Credentials — digunakan oleh seeder untuk membuat akun admin pertama
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-to-a-secure-password
