<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <%- include('../partials/head', { seo: seo || {}, settings: settings, isAdmin: false }) %>
</head>
<body class="min-h-screen bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">

  <%- include('../partials/navbar', { settings: settings, currentPath: currentPath || '' }) %>

  <main id="main-content">

    <%# ── Page Header ────────────────────────────────────────────────────────── %>
    <section class="bg-zinc-950 py-16 sm:py-20" aria-label="Page header">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-3xl font-bold text-white sm:text-4xl">Blog</h1>
          <p class="mt-3 text-zinc-400">Artikel seputar web development, SEO, dan teknologi</p>
        </div>
      </div>
    </section>

    <%# ── Blog List ───────────────────────────────────────────────────────────── %>
    <section class="py-16 sm:py-20" aria-labelledby="blog-list-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <h2 id="blog-list-heading" class="sr-only">Daftar artikel</h2>

        <% if (blogPosts && blogPosts.length > 0) { %>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% blogPosts.forEach(function(post) { %>
          <article class="group flex flex-col overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm transition-shadow hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900">

            <%# Featured Image %>
            <% if (post.featured_image) { %>
            <a href="/blog/<%= post.slug %>" class="block overflow-hidden" tabindex="-1" aria-hidden="true">
              <img
                src="<%= post.featured_image %>"
                alt="<%= post.title %>"
                loading="lazy"
                class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </a>
            <% } %>

            <div class="flex flex-1 flex-col p-5">

              <%# Date %>
              <% if (post.published_at) { %>
              <time
                datetime="<%= new Date(post.published_at).toISOString() %>"
                class="mb-2 block text-xs text-zinc-400 dark:text-zinc-500"
              >
                <%= new Date(post.published_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) %>
              </time>
              <% } %>

              <%# Title %>
              <h3 class="mb-2 text-lg font-semibold leading-snug text-zinc-900 dark:text-white">
                <a href="/blog/<%= post.slug %>" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">
                  <%= post.title %>
                </a>
              </h3>

              <%# Excerpt %>
              <% if (post.excerpt) { %>
              <p class="mb-4 flex-1 line-clamp-3 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
                <%= post.excerpt %>
              </p>
              <% } %>

              <%# Read More %>
              <div class="mt-auto pt-2">
                <a
                  href="/blog/<%= post.slug %>"
                  class="inline-flex items-center gap-1 text-sm font-medium text-cyan-500 transition-colors hover:text-cyan-600 dark:text-cyan-400 dark:hover:text-cyan-300"
                  aria-label="Baca artikel <%= post.title %>"
                >
                  Baca Selengkapnya
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>

            </div>
          </article>
          <% }); %>
        </div>
        <% } else { %>
        <div class="py-20 text-center">
          <p class="text-zinc-500 dark:text-zinc-400">Belum ada artikel yang dipublikasikan.</p>
        </div>
        <% } %>

      </div>
    </section>

  </main>

  <%- include('../partials/footer', { settings: settings, socialLinks: [] }) %>
  <%- include('../partials/scripts') %>
</body>
</html>
