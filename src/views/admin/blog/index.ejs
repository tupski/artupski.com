<%#
  admin/blog/index.ejs — Blog Posts list
  Variables expected:
    - posts           {Array}   All blog post rows
    - pageTitle       {string}
    - activePage      {string}  'blog'
    - successMessage  {string|null}
    - errorMessage    {string|null}
%>
<%
  const content = `
<div class="row">
  <div class="col-12">

    <!-- Header row -->
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h3 class="mb-0">Blog Posts</h3>
        <p class="text-muted mb-0 mt-1">${posts.length} post tersimpan</p>
      </div>
      <a href="/admin/blog/create" class="btn btn-primary d-flex align-items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="20" height="20" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
          <path d="M12 5l0 14" />
          <path d="M5 12l14 0" />
        </svg>
        Tambah Post
      </a>
    </div>

    <!-- Table card -->
    <div class="card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-vcenter table-hover card-table mb-0">
            <thead>
              <tr>
                <th>Judul</th>
                <th class="d-none d-md-table-cell">Slug</th>
                <th class="d-none d-sm-table-cell">Status</th>
                <th class="d-none d-lg-table-cell">Tanggal Publish</th>
                <th class="d-none d-lg-table-cell">Dibuat</th>
                <th class="text-end">Aksi</th>
              </tr>
            </thead>
            <tbody>
              ${posts.length === 0 ? `
              <tr>
                <td colspan="6" class="text-center text-muted py-5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-lg mb-2 d-block mx-auto opacity-50" width="40" height="40" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M6 4h11a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-11a1 1 0 0 1 -1 -1v-14a1 1 0 0 1 1 -1m3 0v18" />
                    <path d="M13 8l2 0" />
                    <path d="M13 12l2 0" />
                  </svg>
                  Belum ada blog post. <a href="/admin/blog/create">Tambah sekarang</a>.
                </td>
              </tr>` : posts.map(post => {
                const createdAt = post.created_at
                  ? new Date(post.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })
                  : '—';
                const publishedAt = post.published_at
                  ? new Date(post.published_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })
                  : '—';
                const statusBadge = post.status === 'published'
                  ? '<span class="badge bg-success-lt text-success">Published</span>'
                  : '<span class="badge bg-secondary-lt text-secondary">Draft</span>';
                const titleEscaped = post.title.replace(/</g, '&lt;').replace(/>/g, '&gt;');
                const slugEscaped  = post.slug.replace(/</g, '&lt;').replace(/>/g, '&gt;');
                return \`
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    \${post.featured_image
                      ? \`<img src="\${post.featured_image}" alt="\${titleEscaped}" class="rounded" style="width:40px;height:40px;object-fit:cover;" loading="lazy">\`
                      : \`<div class="rounded bg-secondary-lt d-flex align-items-center justify-content-center" style="width:40px;height:40px;flex-shrink:0;">
                          <svg xmlns="http://www.w3.org/2000/svg" class="icon text-muted" width="20" height="20" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M15 8h.01" />
                            <path d="M3 6a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v12a3 3 0 0 1 -3 3h-12a3 3 0 0 1 -3 -3v-12z" />
                            <path d="M3 16l5 -5c.928 -.893 2.072 -.893 3 0l4 4" />
                            <path d="M14 14l1 -1c.928 -.893 2.072 -.893 3 0l3 3" />
                          </svg>
                        </div>\`
                    }
                    <div>
                      <div class="fw-medium">\${titleEscaped}</div>
                      <div class="d-sm-none">
                        \${statusBadge}
                      </div>
                    </div>
                  </div>
                </td>
                <td class="d-none d-md-table-cell text-muted small"><code>\${slugEscaped}</code></td>
                <td class="d-none d-sm-table-cell">\${statusBadge}</td>
                <td class="d-none d-lg-table-cell text-muted small">\${publishedAt}</td>
                <td class="d-none d-lg-table-cell text-muted small">\${createdAt}</td>
                <td class="text-end">
                  <div class="d-flex justify-content-end gap-1">
                    <a
                      href="/admin/blog/\${post.id}/edit"
                      class="btn btn-sm btn-outline-secondary"
                      aria-label="Edit \${titleEscaped}"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                        <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z" />
                        <path d="M16 5l3 3" />
                      </svg>
                    </a>
                    <form
                      method="POST"
                      action="/admin/blog/\${post.id}?_method=DELETE"
                      class="d-inline"
                      onsubmit="return confirm('Hapus blog post &quot;\${titleEscaped.replace(/'/g, '\\\\&#39;')}&quot;? Tindakan ini tidak dapat dibatalkan.')"
                    >
                      <button
                        type="submit"
                        class="btn btn-sm btn-outline-danger"
                        aria-label="Hapus \${titleEscaped}"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M4 7l16 0" />
                          <path d="M10 11l0 6" />
                          <path d="M14 11l0 6" />
                          <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                          <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                        </svg>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>\`;
              }).join('')}
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>
`;
%>
<%- include('../../layouts/admin', {
  pageTitle,
  activePage,
  breadcrumbs,
  settings,
  unreadCount,
  content,
  successMessage,
  errorMessage
}) %>
