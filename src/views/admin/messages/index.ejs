<%#
  admin/messages/index.ejs — Admin: Daftar Pesan Masuk
  ============================================================
  Variables expected:
    - pageTitle      {string}  'Pesan Masuk'
    - activePage     {string}  'messages'
    - settings       {object}  res.locals.settings
    - unreadCount    {number}  Unread contact messages count
    - messages       {Array}   All contact messages (sorted created_at DESC)
    - successMessage {string|null}
    - errorMessage   {string|null}
  ============================================================
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('../../partials/head', {
    seo: { metaTitle: pageTitle + ' — Admin' },
    settings: settings,
    isAdmin: true
  }) %>
</head>
<body class="antialiased">

  <%- include('../../partials/sidebar', {
    settings:    settings,
    unreadCount: unreadCount || 0,
    activePage:  'messages'
  }) %>

  <div class="page-wrapper">

    <%# ── Page Header ──────────────────────────────────────────────────────── %>
    <div class="page-header d-print-none">
      <div class="container-xl">
        <div class="row g-2 align-items-center">
          <div class="col">
            <h2 class="page-title">Pesan Masuk</h2>
            <div class="text-muted mt-1">
              Kelola semua pesan dari pengunjung website.
              <% if (unreadCount > 0) { %>
                <span class="badge bg-danger ms-2"><%= unreadCount %> belum dibaca</span>
              <% } %>
            </div>
          </div>
          <div class="col-auto ms-auto d-print-none">
            <div class="d-flex align-items-center gap-2">
              <a
                href="/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-outline-secondary btn-sm d-none d-sm-inline-flex align-items-center gap-1"
                aria-label="View public website"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 6h-6a2 2 0 0 0 -2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-6" />
                  <path d="M11 13l9 -9" />
                  <path d="M15 4h5v5" />
                </svg>
                View Site
              </a>
              <button
                id="theme-toggle"
                type="button"
                aria-label="Toggle dark/light mode"
                class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center"
                style="width:2.25rem; height:2.25rem; padding:0;"
              >
                <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="icon icon-sm d-none" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" />
                  <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7" />
                </svg>
                <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# ── Page Body ─────────────────────────────────────────────────────────── %>
    <div class="page-body">
      <div class="container-xl">

        <%- include('../../partials/alerts', {
          successMessage: successMessage,
          errorMessage:   errorMessage,
          infoMessage:    null
        }) %>

        <div class="card">
          <div class="card-header">
            <h3 class="card-title">
              Semua Pesan
              <% if (messages && messages.length > 0) { %>
                <span class="badge bg-secondary ms-2"><%= messages.length %></span>
              <% } %>
            </h3>
          </div>

          <div class="card-body p-0">
            <% if (!messages || messages.length === 0) { %>
              <div class="empty py-5">
                <div class="empty-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-lg" width="40" height="40" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M3 5a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-6l-4 4v-4h-4a2 2 0 0 1 -2 -2z" />
                  </svg>
                </div>
                <p class="empty-title">Belum ada pesan masuk</p>
                <p class="empty-subtitle text-muted">
                  Pesan dari form kontak website akan muncul di sini.
                </p>
              </div>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-vcenter card-table">
                  <thead>
                    <tr>
                      <th>Pengirim</th>
                      <th>Email</th>
                      <th class="d-none d-md-table-cell">Subjek</th>
                      <th>Status</th>
                      <th class="d-none d-lg-table-cell">Tanggal</th>
                      <th class="w-1">Aksi</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% messages.forEach(function(msg) { %>
                      <tr>
                        <td>
                          <div class="d-flex align-items-center">
                            <span class="avatar avatar-sm me-2 text-uppercase bg-blue-lt">
                              <%= msg.name ? msg.name.charAt(0) : '?' %>
                            </span>
                            <div class="text-truncate" style="max-width:140px;">
                              <a href="/admin/messages/<%= msg.id %>" class="text-body fw-medium text-decoration-none">
                                <%= msg.name %>
                              </a>
                            </div>
                          </div>
                        </td>
                        <td class="text-muted text-truncate" style="max-width:160px;">
                          <a href="mailto:<%= msg.email %>" class="text-muted text-decoration-none">
                            <%= msg.email %>
                          </a>
                        </td>
                        <td class="d-none d-md-table-cell text-truncate" style="max-width:200px;">
                          <%= msg.subject || '(tanpa subjek)' %>
                        </td>
                        <td>
                          <% if (msg.status === 'unread') { %>
                            <span class="badge bg-danger">Belum Dibaca</span>
                          <% } else { %>
                            <span class="badge bg-secondary">Sudah Dibaca</span>
                          <% } %>
                        </td>
                        <td class="d-none d-lg-table-cell text-muted small">
                          <% if (msg.created_at) { %>
                            <%= new Date(msg.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                          <% } else { %>
                            —
                          <% } %>
                        </td>
                        <td>
                          <div class="d-flex gap-1">
                            <a
                              href="/admin/messages/<%= msg.id %>"
                              class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"
                              title="Lihat detail"
                              aria-label="Lihat detail pesan dari <%= msg.name %>"
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="14" height="14" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                                <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6" />
                              </svg>
                              <span class="d-none d-sm-inline">Lihat</span>
                            </a>
                            <form
                              action="/admin/messages/<%= msg.id %>?_method=DELETE"
                              method="POST"
                              class="d-inline"
                              onsubmit="return confirm('Hapus pesan dari <%= msg.name.replace(/'/g, "\\'") %>? Tindakan ini tidak dapat dibatalkan.')"
                            >
                              <button
                                type="submit"
                                class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-1"
                                title="Hapus pesan"
                                aria-label="Hapus pesan dari <%= msg.name %>"
                              >
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="14" height="14" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                  <path d="M4 7l16 0" />
                                  <path d="M10 11l0 6" />
                                  <path d="M14 11l0 6" />
                                  <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                                  <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                                </svg>
                                <span class="d-none d-sm-inline">Hapus</span>
                              </button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>

      </div><%# end container-xl %>
    </div><%# end page-body %>

    <%# ── Footer ─────────────────────────────────────────────────────────── %>
    <footer class="footer footer-transparent d-print-none">
      <div class="container-xl">
        <div class="row text-center align-items-center flex-row-reverse">
          <div class="col-lg-auto ms-lg-auto">
            <ul class="list-inline list-inline-dots mb-0">
              <li class="list-inline-item">
                <a href="/" target="_blank" rel="noopener noreferrer" class="link-secondary">View Site</a>
              </li>
              <li class="list-inline-item">
                <a href="/admin/settings" class="link-secondary">Settings</a>
              </li>
            </ul>
          </div>
          <div class="col-12 col-lg-auto mt-3 mt-lg-0">
            <ul class="list-inline list-inline-dots mb-0">
              <li class="list-inline-item">
                &copy; <%= new Date().getFullYear() %>
                <a href="/" class="link-secondary"><%= (settings && settings.site_name) ? settings.site_name : 'Artupski' %></a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

  </div><%# end .page-wrapper %>

  <%# ── Tabler JS ──────────────────────────────────────────────────────────── %>
  <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/js/tabler.min.js"></script>

  <%# ── Admin JS ───────────────────────────────────────────────────────────── %>
  <script src="/js/admin.js"></script>

  <%# ── Theme toggle sync ──────────────────────────────────────────────────── %>
  <script>
    (function () {
      var btn  = document.getElementById('theme-toggle');
      var sun  = document.getElementById('icon-sun');
      var moon = document.getElementById('icon-moon');

      function syncIcons() {
        var isDark = document.documentElement.classList.contains('dark');
        if (sun)  sun.classList.toggle('d-none', !isDark);
        if (moon) moon.classList.toggle('d-none', isDark);
      }

      syncIcons();

      if (btn) {
        btn.addEventListener('click', function () {
          if (typeof toggleTheme === 'function') {
            toggleTheme();
          } else {
            var isDark = document.documentElement.classList.contains('dark');
            document.documentElement.classList.toggle('dark', !isDark);
            try { localStorage.setItem('theme', isDark ? 'light' : 'dark'); } catch (e) {}
          }
          syncIcons();
        });
      }
    })();
  </script>

</body>
</html>
