<%#
  partials/footer.ejs — Public site footer
  Variables expected:
    - settings     {object}  res.locals.settings
    - socialLinks  {Array}   Active social links (optional — passed by controller)
%>
<% const siteName    = (settings && settings.site_name)    ? settings.site_name    : 'Artupski'; %>
<% const footerText  = (settings && settings.footer_text)  ? settings.footer_text  : null; %>
<% const contactEmail = (settings && settings.contact_email) ? settings.contact_email : null; %>
<% const whatsapp    = (settings && settings.whatsapp_number) ? settings.whatsapp_number : null; %>
<% const address     = (settings && settings.address)      ? settings.address      : null; %>
<% const links       = (typeof socialLinks !== 'undefined' && Array.isArray(socialLinks)) ? socialLinks : []; %>
<% const currentYear = new Date().getFullYear(); %>

<footer class="border-t border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 gap-10 md:grid-cols-3">

      <%# ── Brand Column ──────────────────────────────────────────────────── %>
      <div>
        <a href="/" class="text-xl font-bold text-zinc-900 transition-colors hover:text-cyan-500 dark:text-white dark:hover:text-cyan-400">
          <span class="text-cyan-500 dark:text-cyan-400">&lt;</span><%= siteName %><span class="text-cyan-500 dark:text-cyan-400">/&gt;</span>
        </a>
        <% if (footerText) { %>
          <p class="mt-3 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
            <%- footerText %>
          </p>
        <% } else { %>
          <p class="mt-3 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
            Web Developer &amp; SEO Specialist — building fast, modern, and accessible websites.
          </p>
        <% } %>
      </div>

      <%# ── Contact Info Column ───────────────────────────────────────────── %>
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-zinc-900 dark:text-white">
          Contact
        </h3>
        <ul class="space-y-2 text-sm text-zinc-500 dark:text-zinc-400">
          <% if (contactEmail) { %>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 shrink-0 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href="mailto:<%= contactEmail %>" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">
                <%= contactEmail %>
              </a>
            </li>
          <% } %>
          <% if (whatsapp) { %>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 shrink-0 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href="https://wa.me/<%= whatsapp.replace(/\D/g, '') %>" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">
                <%= whatsapp %>
              </a>
            </li>
          <% } %>
          <% if (address) { %>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 shrink-0 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span><%= address %></span>
            </li>
          <% } %>
        </ul>
      </div>

      <%# ── Social Links Column ───────────────────────────────────────────── %>
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-zinc-900 dark:text-white">
          Follow Me
        </h3>
        <% if (links.length > 0) { %>
          <ul class="flex flex-wrap gap-3" role="list">
            <% links.forEach(function(link) { %>
              <li>
                <a
                  href="<%= link.url %>"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="<%= link.platform %>"
                  class="flex h-11 w-11 items-center justify-center rounded-lg border border-zinc-200 text-zinc-500 transition-colors hover:border-cyan-500 hover:text-cyan-500 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-cyan-400 dark:hover:text-cyan-400"
                >
                  <% if (link.icon) { %>
                    <i class="<%= link.icon %>" aria-hidden="true"></i>
                  <% } else { %>
                    <span class="text-xs font-semibold"><%= link.platform.charAt(0).toUpperCase() %></span>
                  <% } %>
                </a>
              </li>
            <% }); %>
          </ul>
        <% } else { %>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">No social links configured yet.</p>
        <% } %>
      </div>

    </div>

    <%# ── Bottom Bar ─────────────────────────────────────────────────────── %>
    <div class="mt-10 border-t border-zinc-200 pt-6 dark:border-zinc-800">
      <p class="text-center text-sm text-zinc-500 dark:text-zinc-400">
        &copy; <%= currentYear %> <%= siteName %>. All rights reserved.
      </p>
    </div>

  </div>
</footer>
