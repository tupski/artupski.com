<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <%- include('../partials/head', { seo: seo || {}, settings: settings, isAdmin: false }) %>
</head>
<body class="min-h-screen bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">

  <%- include('../partials/navbar', { settings: settings, currentPath: currentPath || '' }) %>

  <main id="main-content">

    <%# ── Breadcrumb ─────────────────────────────────────────────────────────── %>
    <nav class="border-b border-zinc-200 bg-white py-3 dark:border-zinc-800 dark:bg-zinc-950" aria-label="Breadcrumb">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <ol class="flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400" role="list">
          <li><a href="/" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">Home</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li><a href="/services" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">Layanan</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li class="truncate text-zinc-900 dark:text-white" aria-current="page"><%= item.title %></li>
        </ol>
      </div>
    </nav>

    <%# ── Service Detail ─────────────────────────────────────────────────────── %>
    <article class="py-12 sm:py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">

        <%# Header %>
        <header class="mb-10">
          <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center">

            <%# Icon / Image %>
            <% if (item.icon_image) { %>
            <div class="shrink-0">
              <img
                src="<%= item.icon_image %>"
                alt="<%= item.title %> icon"
                loading="lazy"
                class="h-20 w-20 rounded-2xl object-cover shadow-md"
              />
            </div>
            <% } else { %>
            <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-cyan-50 shadow-md dark:bg-cyan-900/30" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m1.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <% } %>

            <div>
              <h1 class="mb-2 text-3xl font-bold text-zinc-900 dark:text-white sm:text-4xl">
                <%= item.title %>
              </h1>
              <% if (item.short_description) { %>
              <p class="text-lg text-zinc-500 dark:text-zinc-400">
                <%= item.short_description %>
              </p>
              <% } %>
              <% if (item.price_label) { %>
              <div class="mt-3">
                <span class="inline-block rounded-full bg-cyan-50 px-4 py-1.5 text-sm font-semibold text-cyan-600 dark:bg-cyan-900/30 dark:text-cyan-400">
                  <%= item.price_label %>
                </span>
              </div>
              <% } %>
            </div>

          </div>
        </header>

        <%# Full Description from Quill %>
        <% if (item.full_description) { %>
        <section aria-labelledby="service-description-heading">
          <h2 id="service-description-heading" class="mb-6 text-xl font-bold text-zinc-900 dark:text-white">
            Detail Layanan
          </h2>
          <div class="prose prose-zinc max-w-none dark:prose-invert">
            <%- item.full_description %>
          </div>
        </section>
        <% } %>

        <%# CTA %>
        <div class="mt-12 rounded-xl border border-cyan-200 bg-cyan-50 p-6 dark:border-cyan-900/50 dark:bg-cyan-900/20">
          <h2 class="mb-2 text-lg font-semibold text-zinc-900 dark:text-white">
            Tertarik dengan layanan ini?
          </h2>
          <p class="mb-4 text-sm text-zinc-600 dark:text-zinc-400">
            Hubungi saya untuk mendiskusikan kebutuhan dan mendapatkan penawaran terbaik.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 rounded-lg bg-cyan-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-cyan-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400"
          >
            Hubungi Saya
          </a>
        </div>

        <%# Back Link %>
        <div class="mt-10 border-t border-zinc-200 pt-8 dark:border-zinc-800">
          <a
            href="/services"
            class="inline-flex items-center gap-2 text-sm font-medium text-zinc-500 transition-colors hover:text-cyan-500 dark:text-zinc-400 dark:hover:text-cyan-400"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Kembali ke Layanan
          </a>
        </div>

      </div>
    </article>

  </main>

  <%- include('../partials/footer', { settings: settings, socialLinks: [] }) %>
  <%- include('../partials/scripts') %>
</body>
</html>
