<%#
  admin/experience/index.ejs — Work Experience list
  Variables expected:
    - pageTitle      {string}  'Work Experience'
    - activePage     {string}  'experience'
    - settings       {object}  res.locals.settings
    - unreadCount    {number}  Unread messages count
    - experiences    {Array}   All experience rows
    - successMessage {string|null}
    - errorMessage   {string|null}
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('../../partials/head', {
    seo: { metaTitle: 'Work Experience — Admin' },
    settings: settings,
    isAdmin: true
  }) %>
</head>
<body class="antialiased">

  <%- include('../../partials/sidebar', {
    settings:    settings,
    unreadCount: unreadCount || 0,
    activePage:  'experience'
  }) %>

  <div class="page-wrapper">

    <%# ── Page Header ──────────────────────────────────────────────────────── %>
    <div class="page-header d-print-none">
      <div class="container-xl">
        <div class="row g-2 align-items-center">
          <div class="col">
            <h2 class="page-title">Work Experience</h2>
            <div class="text-muted mt-1">Kelola riwayat pengalaman kerja.</div>
          </div>
          <div class="col-auto ms-auto d-print-none">
            <a
              href="/admin/experience/create"
              class="btn btn-primary d-inline-flex align-items-center gap-1"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M12 5l0 14" />
                <path d="M5 12l14 0" />
              </svg>
              Tambah Experience
            </a>
          </div>
        </div>
      </div>
    </div>

    <%# ── Page Body ─────────────────────────────────────────────────────────── %>
    <div class="page-body">
      <div class="container-xl">

        <%- include('../../partials/alerts', {
          successMessage: successMessage,
          errorMessage:   errorMessage,
          infoMessage:    null
        }) %>

        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Daftar Experience (<%= experiences ? experiences.length : 0 %>)</h3>
          </div>

          <div class="table-responsive">
            <table class="table table-vcenter card-table">
              <thead>
                <tr>
                  <th>Perusahaan</th>
                  <th>Posisi</th>
                  <th>Mulai</th>
                  <th>Selesai</th>
                  <th>Status</th>
                  <th class="w-1">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% if (experiences && experiences.length > 0) { %>
                  <% experiences.forEach(function(exp) { %>
                    <tr>
                      <td class="fw-semibold"><%= exp.company_name %></td>
                      <td class="text-muted"><%= exp.position %></td>
                      <td class="text-muted">
                        <% if (exp.start_date) { %>
                          <%= new Date(exp.start_date).toLocaleDateString('id-ID', { month: 'short', year: 'numeric' }) %>
                        <% } else { %>
                          —
                        <% } %>
                      </td>
                      <td class="text-muted">
                        <% if (exp.is_current) { %>
                          <span class="badge bg-success-lt">Sekarang</span>
                        <% } else if (exp.end_date) { %>
                          <%= new Date(exp.end_date).toLocaleDateString('id-ID', { month: 'short', year: 'numeric' }) %>
                        <% } else { %>
                          —
                        <% } %>
                      </td>
                      <td>
                        <% if (exp.is_current) { %>
                          <span class="badge bg-success">Aktif</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Selesai</span>
                        <% } %>
                      </td>
                      <td>
                        <div class="d-flex gap-1">
                          <a
                            href="/admin/experience/<%= exp.id %>/edit"
                            class="btn btn-sm btn-outline-secondary"
                            aria-label="Edit <%= exp.company_name %>"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z" />
                              <path d="M16 5l3 3" />
                            </svg>
                            Edit
                          </a>
                          <form
                            action="/admin/experience/<%= exp.id %>?_method=DELETE"
                            method="POST"
                            onsubmit="return confirm('Hapus experience di <%= exp.company_name %>? Tindakan ini tidak dapat dibatalkan.')"
                          >
                            <button
                              type="submit"
                              class="btn btn-sm btn-outline-danger"
                              aria-label="Hapus <%= exp.company_name %>"
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M4 7l16 0" />
                                <path d="M10 11l0 6" />
                                <path d="M14 11l0 6" />
                                <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                                <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                              </svg>
                              Hapus
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                      Belum ada data experience.
                      <a href="/admin/experience/create" class="ms-1">Tambah sekarang &rarr;</a>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>

    <%# ── Footer ─────────────────────────────────────────────────────────── %>
    <footer class="footer footer-transparent d-print-none">
      <div class="container-xl">
        <div class="row text-center align-items-center flex-row-reverse">
          <div class="col-12 col-lg-auto mt-3 mt-lg-0">
            <ul class="list-inline list-inline-dots mb-0">
              <li class="list-inline-item">
                &copy; <%= new Date().getFullYear() %>
                <a href="/" class="link-secondary"><%= (settings && settings.site_name) ? settings.site_name : 'Artupski' %></a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

  </div><%# end .page-wrapper %>

  <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/js/tabler.min.js"></script>
  <script src="/js/admin.js"></script>

</body>
</html>
