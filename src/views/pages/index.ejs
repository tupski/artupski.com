<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <%- include('../partials/head', { seo: seo || {}, settings: settings, isAdmin: false }) %>
</head>
<body class="min-h-screen bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">

  <%- include('../partials/navbar', { settings: settings, currentPath: currentPath || '' }) %>

  <main id="main-content">

    <%# ── Hero Section ──────────────────────────────────────────────────────── %>
    <section class="relative overflow-hidden bg-zinc-950 py-24 sm:py-32" aria-label="Hero">
      <div class="absolute inset-0 bg-gradient-to-br from-zinc-900 via-zinc-950 to-blue-950 opacity-80"></div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">

          <% const heroTitle = (settings && settings.hero_title) ? settings.hero_title : 'Web Developer & SEO Specialist'; %>
          <% const heroSubtitle = (settings && settings.hero_subtitle) ? settings.hero_subtitle : 'Angga Dwy Saputra'; %>
          <% const heroDesc = (settings && settings.hero_description) ? settings.hero_description : 'Membangun website modern, cepat, dan SEO-friendly untuk bisnis Anda.'; %>

          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-cyan-400">
            <%= heroSubtitle %>
          </p>
          <h1 class="mb-6 text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl">
            <%= heroTitle %>
          </h1>
          <p class="mb-10 text-lg leading-relaxed text-zinc-400 sm:text-xl">
            <%= heroDesc %>
          </p>

          <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href="/portfolio"
              class="inline-flex items-center gap-2 rounded-lg bg-cyan-500 px-6 py-3 text-base font-semibold text-white shadow-lg transition-colors hover:bg-cyan-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400"
            >
              Lihat Portfolio
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="/contact"
              class="inline-flex items-center gap-2 rounded-lg border border-zinc-600 px-6 py-3 text-base font-semibold text-zinc-300 transition-colors hover:border-cyan-500 hover:text-cyan-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400"
            >
              Hubungi Saya
            </a>
          </div>

        </div>
      </div>
    </section>

    <%# ── Portfolio Preview ──────────────────────────────────────────────────── %>
    <% if (portfolios && portfolios.length > 0) { %>
    <section class="py-20 sm:py-24" aria-labelledby="portfolio-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="mb-12 text-center">
          <h2 id="portfolio-heading" class="text-2xl font-bold text-zinc-900 dark:text-white md:text-3xl">
            Portfolio Terbaru
          </h2>
          <p class="mt-3 text-zinc-500 dark:text-zinc-400">Beberapa proyek yang telah saya kerjakan</p>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% portfolios.forEach(function(item) { %>
          <article class="group overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm transition-shadow hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900">
            <% if (item.image) { %>
            <a href="/portfolio/<%= item.slug %>" class="block overflow-hidden" tabindex="-1" aria-hidden="true">
              <img
                src="<%= item.image %>"
                alt="<%= item.title %>"
                loading="lazy"
                class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </a>
            <% } %>
            <div class="p-5">
              <% if (item.category) { %>
              <span class="mb-2 inline-block rounded-full bg-cyan-50 px-3 py-1 text-xs font-medium text-cyan-600 dark:bg-cyan-900/30 dark:text-cyan-400">
                <%= item.category %>
              </span>
              <% } %>
              <h3 class="mb-2 text-lg font-semibold text-zinc-900 dark:text-white">
                <a href="/portfolio/<%= item.slug %>" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">
                  <%= item.title %>
                </a>
              </h3>
              <% if (item.short_description) { %>
              <p class="mb-4 line-clamp-2 text-sm text-zinc-500 dark:text-zinc-400">
                <%= item.short_description %>
              </p>
              <% } %>
              <a
                href="/portfolio/<%= item.slug %>"
                class="inline-flex items-center gap-1 text-sm font-medium text-cyan-500 transition-colors hover:text-cyan-600 dark:text-cyan-400 dark:hover:text-cyan-300"
                aria-label="Lihat detail <%= item.title %>"
              >
                Lihat Detail
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
          <% }); %>
        </div>

        <div class="mt-10 text-center">
          <a
            href="/portfolio"
            class="inline-flex items-center gap-2 rounded-lg border border-zinc-300 px-6 py-3 text-sm font-semibold text-zinc-700 transition-colors hover:border-cyan-500 hover:text-cyan-500 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-cyan-400 dark:hover:text-cyan-400"
          >
            Lihat Semua Portfolio
          </a>
        </div>

      </div>
    </section>
    <% } %>

    <%# ── Services Preview ───────────────────────────────────────────────────── %>
    <% if (services && services.length > 0) { %>
    <section class="bg-zinc-50 py-20 dark:bg-zinc-900 sm:py-24" aria-labelledby="services-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="mb-12 text-center">
          <h2 id="services-heading" class="text-2xl font-bold text-zinc-900 dark:text-white md:text-3xl">
            Layanan
          </h2>
          <p class="mt-3 text-zinc-500 dark:text-zinc-400">Apa yang bisa saya bantu untuk Anda</p>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% services.forEach(function(service) { %>
          <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md dark:border-zinc-800 dark:bg-zinc-950">
            <% if (service.icon_image) { %>
            <div class="mb-4">
              <img
                src="<%= service.icon_image %>"
                alt="<%= service.title %> icon"
                loading="lazy"
                class="h-12 w-12 rounded-lg object-cover"
              />
            </div>
            <% } else { %>
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-50 dark:bg-cyan-900/30" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m1.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <% } %>
            <h3 class="mb-2 text-lg font-semibold text-zinc-900 dark:text-white">
              <a href="/services/<%= service.slug %>" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">
                <%= service.title %>
              </a>
            </h3>
            <% if (service.short_description) { %>
            <p class="mb-4 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
              <%= service.short_description %>
            </p>
            <% } %>
            <% if (service.price_label) { %>
            <p class="text-sm font-semibold text-cyan-500 dark:text-cyan-400">
              <%= service.price_label %>
            </p>
            <% } %>
          </article>
          <% }); %>
        </div>

        <div class="mt-10 text-center">
          <a
            href="/services"
            class="inline-flex items-center gap-2 rounded-lg border border-zinc-300 px-6 py-3 text-sm font-semibold text-zinc-700 transition-colors hover:border-cyan-500 hover:text-cyan-500 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-cyan-400 dark:hover:text-cyan-400"
          >
            Lihat Semua Layanan
          </a>
        </div>

      </div>
    </section>
    <% } %>

    <%# ── Blog Preview ────────────────────────────────────────────────────────── %>
    <% if (blogPosts && blogPosts.length > 0) { %>
    <section class="py-20 sm:py-24" aria-labelledby="blog-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="mb-12 text-center">
          <h2 id="blog-heading" class="text-2xl font-bold text-zinc-900 dark:text-white md:text-3xl">
            Artikel Terbaru
          </h2>
          <p class="mt-3 text-zinc-500 dark:text-zinc-400">Tulisan seputar web development dan SEO</p>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% blogPosts.forEach(function(post) { %>
          <article class="group overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm transition-shadow hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900">
            <% if (post.featured_image) { %>
            <a href="/blog/<%= post.slug %>" class="block overflow-hidden" tabindex="-1" aria-hidden="true">
              <img
                src="<%= post.featured_image %>"
                alt="<%= post.title %>"
                loading="lazy"
                class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </a>
            <% } %>
            <div class="p-5">
              <% if (post.published_at) { %>
              <time
                datetime="<%= new Date(post.published_at).toISOString() %>"
                class="mb-2 block text-xs text-zinc-400 dark:text-zinc-500"
              >
                <%= new Date(post.published_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) %>
              </time>
              <% } %>
              <h3 class="mb-2 text-lg font-semibold text-zinc-900 dark:text-white">
                <a href="/blog/<%= post.slug %>" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">
                  <%= post.title %>
                </a>
              </h3>
              <% if (post.excerpt) { %>
              <p class="mb-4 line-clamp-2 text-sm text-zinc-500 dark:text-zinc-400">
                <%= post.excerpt %>
              </p>
              <% } %>
              <a
                href="/blog/<%= post.slug %>"
                class="inline-flex items-center gap-1 text-sm font-medium text-cyan-500 transition-colors hover:text-cyan-600 dark:text-cyan-400 dark:hover:text-cyan-300"
                aria-label="Baca artikel <%= post.title %>"
              >
                Baca Selengkapnya
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
          <% }); %>
        </div>

        <div class="mt-10 text-center">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 rounded-lg border border-zinc-300 px-6 py-3 text-sm font-semibold text-zinc-700 transition-colors hover:border-cyan-500 hover:text-cyan-500 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-cyan-400 dark:hover:text-cyan-400"
          >
            Lihat Semua Artikel
          </a>
        </div>

      </div>
    </section>
    <% } %>

    <%# ── CTA Section ─────────────────────────────────────────────────────────── %>
    <section class="bg-cyan-500 py-16 dark:bg-cyan-600" aria-labelledby="cta-heading">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
        <h2 id="cta-heading" class="mb-4 text-2xl font-bold text-white md:text-3xl">
          Siap Memulai Proyek Bersama?
        </h2>
        <p class="mb-8 text-cyan-100">
          Mari diskusikan kebutuhan website atau SEO Anda. Saya siap membantu.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-base font-semibold text-cyan-600 shadow-md transition-colors hover:bg-cyan-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
        >
          Mulai Diskusi
        </a>
      </div>
    </section>

  </main>

  <%- include('../partials/footer', { settings: settings, socialLinks: [] }) %>
  <%- include('../partials/scripts') %>
</body>
</html>
