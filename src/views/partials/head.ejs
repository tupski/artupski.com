<%#
  partials/head.ejs — HTML <head> partial
  Variables expected:
    - title        {string}  Page title (already processed by SEO_Helper)
    - seo          {object}  { metaTitle, metaDescription, canonical, og }
    - settings     {object}  res.locals.settings (site_name, favicon, etc.)
    - isAdmin      {boolean} If true, load Tabler CSS instead of Tailwind output
%>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<%# ── Favicon ──────────────────────────────────────────────────────────────── %>
<% const faviconPath = (settings && settings.favicon) ? settings.favicon : '/images/favicon.ico'; %>
<link rel="icon" type="image/x-icon" href="<%= faviconPath %>" />

<%# ── Page Title ──────────────────────────────────────────────────────────── %>
<% const pageTitle = (seo && seo.metaTitle) ? seo.metaTitle : (settings && settings.site_name ? settings.site_name : 'Artupski'); %>
<title><%= pageTitle %></title>

<%# ── SEO Meta Tags ───────────────────────────────────────────────────────── %>
<% if (seo && seo.metaDescription) { %>
<meta name="description" content="<%= seo.metaDescription %>" />
<% } %>
<% if (seo && seo.canonical) { %>
<link rel="canonical" href="<%= seo.canonical %>" />
<% } %>

<%# ── Open Graph Tags ─────────────────────────────────────────────────────── %>
<% if (seo && seo.og) { %>
<meta property="og:type"        content="<%= seo.og.type || 'website' %>" />
<meta property="og:title"       content="<%= seo.og.title || pageTitle %>" />
<% if (seo.og.description) { %>
<meta property="og:description" content="<%= seo.og.description %>" />
<% } %>
<% if (seo.og.url) { %>
<meta property="og:url"         content="<%= seo.og.url %>" />
<% } %>
<% if (seo.og.image) { %>
<meta property="og:image"       content="<%= seo.og.image %>" />
<% } %>
<% } %>

<%# ── Theme: apply dark class before render to prevent flickering ─────────── %>
<script>
  (function () {
    try {
      var theme = localStorage.getItem('theme');
      if (!theme) { theme = 'dark'; }
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    } catch (e) {
      document.documentElement.classList.add('dark');
    }
  })();
</script>

<% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
<%# ── Admin: Tabler CSS (CDN) ─────────────────────────────────────────────── %>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/css/tabler.min.css"
/>
<% } else { %>
<%# ── Public: TailwindCSS compiled output ────────────────────────────────── %>
<link rel="stylesheet" href="/css/output.css" />
<% } %>
