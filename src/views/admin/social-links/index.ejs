<%#
  admin/social-links/index.ejs — Social Links List
  ============================================================
  Variables expected:
    - pageTitle      {string}  'Social Links'
    - activePage     {string}  'social-links'
    - settings       {object}  res.locals.settings
    - unreadCount    {number}  Unread contact messages count
    - socialLinks    {Array}   All social link rows
    - successMessage {string|null}
    - errorMessage   {string|null}
  ============================================================
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('../../partials/head', {
    seo: { metaTitle: 'Social Links — Admin' },
    settings: settings,
    isAdmin: true
  }) %>
</head>
<body class="antialiased">

  <%- include('../../partials/sidebar', {
    settings:    settings,
    unreadCount: unreadCount || 0,
    activePage:  'social-links'
  }) %>

  <div class="page-wrapper">

    <%# ── Page Header ──────────────────────────────────────────────────────── %>
    <div class="page-header d-print-none">
      <div class="container-xl">
        <div class="row g-2 align-items-center">
          <div class="col">
            <h2 class="page-title">Social Links</h2>
            <div class="text-muted mt-1">Kelola tautan media sosial yang tampil di website.</div>
          </div>
          <div class="col-auto ms-auto d-print-none">
            <div class="d-flex align-items-center gap-2">
              <a
                href="/admin/social-links/create"
                class="btn btn-primary d-inline-flex align-items-center gap-1"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 5l0 14" />
                  <path d="M5 12l14 0" />
                </svg>
                Tambah Social Link
              </a>
              <button
                id="theme-toggle"
                type="button"
                aria-label="Toggle dark/light mode"
                class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center"
                style="width:2.25rem; height:2.25rem; padding:0;"
              >
                <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="icon icon-sm d-none" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" />
                  <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7" />
                </svg>
                <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# ── Page Body ─────────────────────────────────────────────────────────── %>
    <div class="page-body">
      <div class="container-xl">

        <%- include('../../partials/alerts', {
          successMessage: successMessage,
          errorMessage:   errorMessage,
          infoMessage:    null
        }) %>

        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Daftar Social Links</h3>
            <div class="card-options">
              <span class="text-muted small"><%= socialLinks ? socialLinks.length : 0 %> link</span>
            </div>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
            <table class="table table-vcenter card-table">
              <thead>
                <tr>
                  <th>Platform</th>
                  <th>URL</th>
                  <th>Icon CSS Class</th>
                  <th>Status</th>
                  <th class="w-1">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% if (socialLinks && socialLinks.length > 0) { %>
                  <% socialLinks.forEach(function(link) { %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center gap-2">
                          <% if (link.icon) { %>
                            <i class="<%= link.icon %>" aria-hidden="true" style="font-size:1.1rem; width:1.25rem; text-align:center;"></i>
                          <% } else { %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm text-muted" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M6 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
                              <path d="M18 6m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
                              <path d="M18 18m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
                              <path d="M8.7 10.7l6.6 -3.4" />
                              <path d="M8.7 13.3l6.6 3.4" />
                            </svg>
                          <% } %>
                          <span class="fw-medium"><%= link.platform %></span>
                        </div>
                      </td>
                      <td>
                        <a
                          href="<%= link.url %>"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-secondary text-truncate d-inline-block"
                          style="max-width: 260px;"
                          title="<%= link.url %>"
                        >
                          <%= link.url %>
                        </a>
                      </td>
                      <td>
                        <% if (link.icon) { %>
                          <code class="small"><%= link.icon %></code>
                        <% } else { %>
                          <span class="text-muted">—</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (link.is_active) { %>
                          <span class="badge bg-success">Aktif</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Nonaktif</span>
                        <% } %>
                      </td>
                      <td>
                        <div class="d-flex gap-1">
                          <a
                            href="/admin/social-links/<%= link.id %>/edit"
                            class="btn btn-sm btn-outline-primary"
                            aria-label="Edit <%= link.platform %>"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="14" height="14" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z" />
                              <path d="M16 5l3 3" />
                            </svg>
                            Edit
                          </a>
                          <form
                            action="/admin/social-links/<%= link.id %>/delete"
                            method="POST"
                            onsubmit="return confirm('Hapus social link <%= link.platform %>? Tindakan ini tidak dapat dibatalkan.')"
                          >
                            <button
                              type="submit"
                              class="btn btn-sm btn-outline-danger"
                              aria-label="Hapus <%= link.platform %>"
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="14" height="14" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M4 7l16 0" />
                                <path d="M10 11l0 6" />
                                <path d="M14 11l0 6" />
                                <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                                <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                              </svg>
                              Hapus
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                      Belum ada social link. <a href="/admin/social-links/create">Tambah sekarang</a>.
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
          </div>
        </div>

      </div><%# end container-xl %>
    </div><%# end page-body %>

    <%# ── Footer ─────────────────────────────────────────────────────────── %>
    <footer class="footer footer-transparent d-print-none">
      <div class="container-xl">
        <div class="row text-center align-items-center flex-row-reverse">
          <div class="col-lg-auto ms-lg-auto">
            <ul class="list-inline list-inline-dots mb-0">
              <li class="list-inline-item">
                <a href="/" target="_blank" rel="noopener noreferrer" class="link-secondary">View Site</a>
              </li>
              <li class="list-inline-item">
                <a href="/admin/settings" class="link-secondary">Settings</a>
              </li>
            </ul>
          </div>
          <div class="col-12 col-lg-auto mt-3 mt-lg-0">
            <ul class="list-inline list-inline-dots mb-0">
              <li class="list-inline-item">
                &copy; <%= new Date().getFullYear() %>
                <a href="/" class="link-secondary"><%= (settings && settings.site_name) ? settings.site_name : 'Artupski' %></a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

  </div><%# end .page-wrapper %>

  <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/js/tabler.min.js"></script>
  <script src="/js/admin.js"></script>
  <script>
    (function () {
      var btn  = document.getElementById('theme-toggle');
      var sun  = document.getElementById('icon-sun');
      var moon = document.getElementById('icon-moon');
      function syncIcons() {
        var isDark = document.documentElement.classList.contains('dark');
        if (sun)  sun.classList.toggle('d-none', !isDark);
        if (moon) moon.classList.toggle('d-none', isDark);
      }
      syncIcons();
      if (btn) {
        btn.addEventListener('click', function () {
          if (typeof toggleTheme === 'function') { toggleTheme(); }
          else {
            var isDark = document.documentElement.classList.contains('dark');
            document.documentElement.classList.toggle('dark', !isDark);
            try { localStorage.setItem('theme', isDark ? 'light' : 'dark'); } catch (e) {}
          }
          syncIcons();
        });
      }
    })();
  </script>

</body>
</html>
