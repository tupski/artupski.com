<%#
  admin/login.ejs — Admin login page
  Standalone page (no sidebar layout), centered card design using Tabler CSS.

  Variables expected:
    - settings  {object}  res.locals.settings (site_name, favicon, etc.)
    - error     {string|null}  Error message to display, or null
%>
<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('../partials/head', {
    seo: { metaTitle: 'Admin Login — ' + ((settings && settings.site_name) ? settings.site_name : 'Artupski') },
    settings: settings,
    isAdmin: true
  }) %>
</head>
<body class="antialiased">

  <%# ── Centered page wrapper (Tabler utility) ──────────────────────────── %>
  <div class="page page-center">
    <div class="container container-tight py-4">

      <%# ── Site branding ──────────────────────────────────────────────── %>
      <div class="text-center mb-4">
        <% if (settings && settings.logo) { %>
          <img
            src="<%= settings.logo %>"
            alt="<%= settings.site_name || 'Logo' %>"
            class="h-10 mx-auto mb-3"
            loading="lazy"
          />
        <% } %>
        <h1 class="h3 mb-0">
          <%= (settings && settings.site_name) ? settings.site_name : 'Artupski' %>
        </h1>
        <% if (settings && settings.tagline) { %>
          <p class="text-muted mt-1"><%= settings.tagline %></p>
        <% } %>
      </div>

      <%# ── Login card ──────────────────────────────────────────────────── %>
      <div class="card card-md shadow-sm">
        <div class="card-body">

          <h2 class="h2 text-center mb-4">Masuk ke Admin Panel</h2>

          <%# ── Error alert ─────────────────────────────────────────────── %>
          <% if (error) { %>
            <div class="alert alert-danger alert-dismissible" role="alert">
              <div class="d-flex">
                <div>
                  <%# Tabler alert icon %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" />
                    <path d="M12 8v4" />
                    <path d="M12 16h.01" />
                  </svg>
                </div>
                <div><%= error %></div>
              </div>
              <a class="btn-close" data-bs-dismiss="alert" aria-label="Tutup"></a>
            </div>
          <% } %>

          <%# ── Login form ───────────────────────────────────────────────── %>
          <form action="/admin/login" method="POST" novalidate>

            <div class="mb-3">
              <label for="email" class="form-label">Alamat Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-control"
                placeholder="admin@example.com"
                autocomplete="email"
                required
                autofocus
              />
            </div>

            <div class="mb-3">
              <label for="password" class="form-label">
                Password
                <span class="form-label-description">
                  <a href="#" tabindex="-1" class="text-muted" style="pointer-events: none; cursor: default;">Lupa password?</a>
                </span>
              </label>
              <div class="input-group input-group-flat">
                <input
                  type="password"
                  id="password"
                  name="password"
                  class="form-control"
                  placeholder="••••••••"
                  autocomplete="current-password"
                  required
                />
                <span class="input-group-text">
                  <button
                    type="button"
                    class="link-secondary"
                    id="toggle-password"
                    aria-label="Tampilkan atau sembunyikan password"
                    title="Tampilkan password"
                    tabindex="-1"
                  >
                    <%# Eye icon — show password %>
                    <svg xmlns="http://www.w3.org/2000/svg" id="icon-eye" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                      <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6" />
                    </svg>
                    <%# Eye-off icon — hide password (hidden by default) %>
                    <svg xmlns="http://www.w3.org/2000/svg" id="icon-eye-off" class="icon d-none" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M10.585 10.587a2 2 0 0 0 2.829 2.828" />
                      <path d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87" />
                      <path d="M3 3l18 18" />
                    </svg>
                  </button>
                </span>
              </div>
            </div>

            <div class="form-footer">
              <button type="submit" class="btn btn-primary w-100">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M14 8v-2a2 2 0 0 0 -2 -2h-7a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2 -2v-2" />
                  <path d="M20 12h-13l3 -3m0 6l-3 -3" />
                </svg>
                Masuk
              </button>
            </div>

          </form>

        </div>
      </div>

      <%# ── Footer note ─────────────────────────────────────────────────── %>
      <div class="text-center text-muted mt-3">
        <small>
          &copy; <%= new Date().getFullYear() %>
          <%= (settings && settings.site_name) ? settings.site_name : 'Artupski' %>.
          Hak cipta dilindungi.
        </small>
      </div>

    </div>
  </div>

  <%# ── Tabler JS (CDN) ─────────────────────────────────────────────────── %>
  <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/js/tabler.min.js"></script>

  <%# ── Password visibility toggle ─────────────────────────────────────── %>
  <script>
    (function () {
      var btn     = document.getElementById('toggle-password');
      var input   = document.getElementById('password');
      var iconEye    = document.getElementById('icon-eye');
      var iconEyeOff = document.getElementById('icon-eye-off');

      if (!btn || !input) return;

      btn.addEventListener('click', function () {
        var isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        iconEye.classList.toggle('d-none', isHidden);
        iconEyeOff.classList.toggle('d-none', !isHidden);
        btn.setAttribute('title', isHidden ? 'Sembunyikan password' : 'Tampilkan password');
      });
    })();
  </script>

</body>
</html>
