<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <%- include('../partials/head', { seo: seo || {}, settings: settings, isAdmin: false }) %>
</head>
<body class="min-h-screen bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">

  <%- include('../partials/navbar', { settings: settings, currentPath: currentPath || '' }) %>

  <main id="main-content">

    <%# ── Breadcrumb ─────────────────────────────────────────────────────────── %>
    <nav class="border-b border-zinc-200 bg-white py-3 dark:border-zinc-800 dark:bg-zinc-950" aria-label="Breadcrumb">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <ol class="flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400" role="list">
          <li><a href="/" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">Home</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li><a href="/portfolio" class="transition-colors hover:text-cyan-500 dark:hover:text-cyan-400">Portfolio</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li class="truncate text-zinc-900 dark:text-white" aria-current="page"><%= item.title %></li>
        </ol>
      </div>
    </nav>

    <%# ── Portfolio Detail ───────────────────────────────────────────────────── %>
    <article class="py-12 sm:py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">

        <%# Header %>
        <header class="mb-8">
          <% if (item.category) { %>
          <span class="mb-3 inline-block rounded-full bg-cyan-50 px-3 py-1 text-sm font-medium text-cyan-600 dark:bg-cyan-900/30 dark:text-cyan-400">
            <%= item.category %>
          </span>
          <% } %>
          <h1 class="mb-4 text-3xl font-bold text-zinc-900 dark:text-white sm:text-4xl">
            <%= item.title %>
          </h1>
          <% if (item.short_description) { %>
          <p class="text-lg leading-relaxed text-zinc-500 dark:text-zinc-400">
            <%= item.short_description %>
          </p>
          <% } %>
        </header>

        <%# Featured Image %>
        <% if (item.image) { %>
        <figure class="mb-10 overflow-hidden rounded-xl">
          <img
            src="<%= item.image %>"
            alt="<%= item.title %>"
            loading="lazy"
            class="w-full object-cover"
          />
        </figure>
        <% } %>

        <div class="grid grid-cols-1 gap-10 lg:grid-cols-3">

          <%# Main Content %>
          <div class="lg:col-span-2">
            <% if (item.full_description) { %>
            <section aria-labelledby="description-heading">
              <h2 id="description-heading" class="mb-4 text-xl font-bold text-zinc-900 dark:text-white">
                Deskripsi Proyek
              </h2>
              <div class="prose prose-zinc max-w-none dark:prose-invert">
                <%- item.full_description %>
              </div>
            </section>
            <% } %>
          </div>

          <%# Sidebar Info %>
          <aside class="space-y-6" aria-label="Informasi proyek">

            <%# Tech Stack %>
            <% if (item.tech_stack) { %>
            <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-5 dark:border-zinc-800 dark:bg-zinc-900">
              <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
                Tech Stack
              </h2>
              <%
                let techItems = [];
                try {
                  techItems = JSON.parse(item.tech_stack);
                } catch(e) {
                  techItems = item.tech_stack.split(',').map(function(t) { return t.trim(); });
                }
              %>
              <ul class="flex flex-wrap gap-2" role="list">
                <% techItems.forEach(function(tech) { %>
                <li>
                  <span class="rounded-md bg-white px-3 py-1 text-sm font-medium text-zinc-700 shadow-sm ring-1 ring-zinc-200 dark:bg-zinc-800 dark:text-zinc-300 dark:ring-zinc-700">
                    <%= tech %>
                  </span>
                </li>
                <% }); %>
              </ul>
            </div>
            <% } %>

            <%# Client %>
            <% if (item.client_name) { %>
            <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-5 dark:border-zinc-800 dark:bg-zinc-900">
              <h2 class="mb-1 text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
                Klien
              </h2>
              <p class="font-medium text-zinc-900 dark:text-white"><%= item.client_name %></p>
            </div>
            <% } %>

            <%# Links %>
            <% if (item.demo_link || item.github_link) { %>
            <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-5 dark:border-zinc-800 dark:bg-zinc-900">
              <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
                Links
              </h2>
              <div class="flex flex-col gap-3">
                <% if (item.demo_link) { %>
                <a
                  href="<%= item.demo_link %>"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-2 rounded-lg bg-cyan-500 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-cyan-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Live Demo
                </a>
                <% } %>
                <% if (item.github_link) { %>
                <a
                  href="<%= item.github_link %>"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-2 rounded-lg border border-zinc-300 px-4 py-2.5 text-sm font-semibold text-zinc-700 transition-colors hover:border-zinc-900 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-white dark:hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-zinc-400"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
                <% } %>
              </div>
            </div>
            <% } %>

          </aside>
        </div>

        <%# Back Link %>
        <div class="mt-12 border-t border-zinc-200 pt-8 dark:border-zinc-800">
          <a
            href="/portfolio"
            class="inline-flex items-center gap-2 text-sm font-medium text-zinc-500 transition-colors hover:text-cyan-500 dark:text-zinc-400 dark:hover:text-cyan-400"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Kembali ke Portfolio
          </a>
        </div>

      </div>
    </article>

  </main>

  <%- include('../partials/footer', { settings: settings, socialLinks: [] }) %>
  <%- include('../partials/scripts') %>
</body>
</html>
