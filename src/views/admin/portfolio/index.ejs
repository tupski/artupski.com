<%#
  admin/portfolio/index.ejs — Portfolio List
  ============================================================
  Variables expected:
    - pageTitle      {string}  'Portfolio'
    - activePage     {string}  'portfolio'
    - settings       {object}  res.locals.settings
    - unreadCount    {number}  Unread contact messages count
    - portfolios     {Array}   All portfolio items
    - successMessage {string|null}
    - errorMessage   {string|null}
  ============================================================
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('../../partials/head', {
    seo: { metaTitle: 'Portfolio — Admin' },
    settings: settings,
    isAdmin: true
  }) %>
</head>
<body class="antialiased">

  <%- include('../../partials/sidebar', {
    settings:    settings,
    unreadCount: unreadCount || 0,
    activePage:  'portfolio'
  }) %>

  <div class="page-wrapper">

    <%# ── Page Header ──────────────────────────────────────────────────────── %>
    <div class="page-header d-print-none">
      <div class="container-xl">
        <div class="row g-2 align-items-center">
          <div class="col">
            <h2 class="page-title">Portfolio</h2>
            <div class="text-muted mt-1">Kelola semua item portfolio.</div>
          </div>
          <div class="col-auto ms-auto d-print-none">
            <div class="d-flex align-items-center gap-2">
              <a
                href="/admin/portfolio/create"
                class="btn btn-primary d-inline-flex align-items-center gap-1"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 5l0 14" />
                  <path d="M5 12l14 0" />
                </svg>
                Tambah Portfolio
              </a>
              <button
                id="theme-toggle"
                type="button"
                aria-label="Toggle dark/light mode"
                class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center"
                style="width:2.25rem; height:2.25rem; padding:0;"
              >
                <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="icon icon-sm d-none" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" />
                  <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7" />
                </svg>
                <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# ── Page Body ─────────────────────────────────────────────────────────── %>
    <div class="page-body">
      <div class="container-xl">

        <%- include('../../partials/alerts', {
          successMessage: successMessage,
          errorMessage:   errorMessage,
          infoMessage:    null
        }) %>

        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Daftar Portfolio (<%= portfolios.length %>)</h3>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-vcenter card-table">
                <thead>
                  <tr>
                    <th>Judul</th>
                    <th>Kategori</th>
                    <th>Status</th>
                    <th>Tanggal Dibuat</th>
                    <th class="w-1">Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (portfolios && portfolios.length > 0) { %>
                    <% portfolios.forEach(function(item) { %>
                      <tr>
                        <td>
                          <div class="d-flex align-items-center gap-2">
                            <% if (item.image) { %>
                              <span
                                class="avatar avatar-sm rounded"
                                style="background-image: url('<%= item.image %>')"
                                aria-hidden="true"
                              ></span>
                            <% } else { %>
                              <span class="avatar avatar-sm rounded bg-secondary-lt text-secondary" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                  <path d="M15 8h.01" />
                                  <path d="M3 6a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v12a3 3 0 0 1 -3 3h-12a3 3 0 0 1 -3 -3z" />
                                  <path d="M3 16l5 -5c.928 -.893 2.072 -.893 3 0l4 4" />
                                  <path d="M14 14l1 -1c.928 -.893 2.072 -.893 3 0l3 3" />
                                </svg>
                              </span>
                            <% } %>
                            <div>
                              <div class="fw-medium"><%= item.title %></div>
                              <div class="text-muted small text-truncate" style="max-width:220px;">
                                <%= item.slug %>
                              </div>
                            </div>
                          </div>
                        </td>
                        <td>
                          <% if (item.category) { %>
                            <span class="badge bg-blue-lt text-blue"><%= item.category %></span>
                          <% } else { %>
                            <span class="text-muted">—</span>
                          <% } %>
                        </td>
                        <td>
                          <% if (item.status === 'published') { %>
                            <span class="badge bg-success">Published</span>
                          <% } else { %>
                            <span class="badge bg-secondary">Draft</span>
                          <% } %>
                        </td>
                        <td class="text-muted small">
                          <%= item.created_at
                            ? new Date(item.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })
                            : '—' %>
                        </td>
                        <td>
                          <div class="d-flex gap-1">
                            <a
                              href="/admin/portfolio/<%= item.id %>/edit"
                              class="btn btn-sm btn-outline-primary"
                              aria-label="Edit <%= item.title %>"
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                                <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z" />
                                <path d="M16 5l3 3" />
                              </svg>
                              Edit
                            </a>
                            <form
                              action="/admin/portfolio/<%= item.id %>?_method=DELETE"
                              method="POST"
                              class="d-inline"
                              onsubmit="return confirmDelete('<%= item.title.replace(/'/g, "\\'") %>')"
                            >
                              <button
                                type="submit"
                                class="btn btn-sm btn-outline-danger"
                                aria-label="Hapus <%= item.title %>"
                              >
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                  <path d="M4 7l16 0" />
                                  <path d="M10 11l0 6" />
                                  <path d="M14 11l0 6" />
                                  <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                                  <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                                </svg>
                                Hapus
                              </button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="5" class="text-center text-muted py-4">
                        Belum ada portfolio. <a href="/admin/portfolio/create">Tambah sekarang</a>.
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

      </div>
    </div>

    <%# ── Footer ─────────────────────────────────────────────────────────── %>
    <footer class="footer footer-transparent d-print-none">
      <div class="container-xl">
        <div class="row text-center align-items-center flex-row-reverse">
          <div class="col-12 col-lg-auto mt-3 mt-lg-0">
            <ul class="list-inline list-inline-dots mb-0">
              <li class="list-inline-item">
                &copy; <%= new Date().getFullYear() %>
                <a href="/" class="link-secondary"><%= (settings && settings.site_name) ? settings.site_name : 'Artupski' %></a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

  </div><%# end .page-wrapper %>

  <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/js/tabler.min.js"></script>
  <script src="/js/admin.js"></script>
  <script>
    // Theme toggle sync
    (function () {
      var btn  = document.getElementById('theme-toggle');
      var sun  = document.getElementById('icon-sun');
      var moon = document.getElementById('icon-moon');
      function syncIcons() {
        var isDark = document.documentElement.classList.contains('dark');
        if (sun)  sun.classList.toggle('d-none', !isDark);
        if (moon) moon.classList.toggle('d-none', isDark);
      }
      syncIcons();
      if (btn) {
        btn.addEventListener('click', function () {
          if (typeof toggleTheme === 'function') { toggleTheme(); }
          else {
            var isDark = document.documentElement.classList.contains('dark');
            document.documentElement.classList.toggle('dark', !isDark);
            try { localStorage.setItem('theme', isDark ? 'light' : 'dark'); } catch (e) {}
          }
          syncIcons();
        });
      }
    })();

    // Delete confirmation dialog
    function confirmDelete(title) {
      return window.confirm('Hapus portfolio "' + title + '"?\nTindakan ini tidak dapat dibatalkan.');
    }
  </script>

</body>
</html>
