<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <%- include('../partials/head', { seo: seo || {}, settings: settings, isAdmin: false }) %>
</head>
<body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">

  <%- include('../partials/navbar', { settings: settings, currentPath: currentPath || '' }) %>

  <main id="main-content">

    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <%# HERO SECTION %>
    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <section class="relative overflow-hidden bg-zinc-950 pt-16 pb-20 sm:pt-20 sm:pb-28" aria-label="Hero">

      <%# Background gradient blobs %>
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute -top-40 -right-40 h-96 w-96 rounded-full bg-blue-600/20 blur-3xl"></div>
        <div class="absolute top-20 left-1/3 h-64 w-64 rounded-full bg-cyan-500/10 blur-3xl"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">

          <%# Left: text content %>
          <div>
            <%# Badge %>
            <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-cyan-500/30 bg-cyan-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-cyan-400">
              <span class="h-1.5 w-1.5 rounded-full bg-cyan-400"></span>
              Halo, Saya Angga
            </div>

            <%# Headline %>
            <%
              const heroTitle    = (settings && settings.hero_title)       ? settings.hero_title       : 'Web Developer,';
              const heroSubtitle = (settings && settings.hero_subtitle)    ? settings.hero_subtitle    : 'SEO Specialist & IT Support';
              const heroDesc     = (settings && settings.hero_description) ? settings.hero_description : 'Saya membantu bisnis dan individu membangun website modern, cepat, SEO-friendly dan mudah dikelola.';
            %>
            <h1 class="mb-5 text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
              <%= heroTitle %><br>
              <span class="text-cyan-400"><%= heroSubtitle.split('&')[0].trim() %></span>
              <% if (heroSubtitle.includes('&')) { %>
              &amp; <span class="text-white"><%= heroSubtitle.split('&')[1].trim() %></span>
              <% } %>
            </h1>
            <p class="mb-8 max-w-lg text-base leading-relaxed text-zinc-400 sm:text-lg">
              <%= heroDesc %>
            </p>

            <%# CTA buttons %>
            <div class="mb-8 flex flex-wrap items-center gap-4">
              <a href="/portfolio" class="inline-flex items-center gap-2 rounded-lg bg-cyan-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-cyan-500/25 transition-all hover:bg-cyan-400 hover:shadow-cyan-400/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400">
                Lihat Portfolio
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
              <a href="/contact" class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 px-6 py-3 text-sm font-semibold text-zinc-300 transition-colors hover:border-zinc-500 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-zinc-500">
                Hubungi Saya
              </a>
            </div>

            <%# Social icons row %>
            <div class="flex items-center gap-3">
              <span class="text-xs text-zinc-500">Follow:</span>
              <% const socialPlatforms = [
                { name: 'GitHub',    href: 'https://github.com',    icon: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z' },
                { name: 'LinkedIn',  href: 'https://linkedin.com',  icon: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z' },
                { name: 'Instagram', href: 'https://instagram.com', icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z' },
                { name: 'WhatsApp',  href: 'https://wa.me',         icon: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z' },
              ]; %>
              <% socialPlatforms.forEach(function(s) { %>
              <a href="<%= s.href %>" target="_blank" rel="noopener noreferrer" aria-label="<%= s.name %>"
                 class="flex h-8 w-8 items-center justify-center rounded-lg border border-zinc-800 text-zinc-500 transition-colors hover:border-cyan-500/50 hover:text-cyan-400">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="<%= s.icon %>"/></svg>
              </a>
              <% }); %>
            </div>
          </div>

          <%# Right: hero image + availability badge %>
          <div class="relative flex justify-center lg:justify-end">
            <div class="relative">
              <%# Decorative ring %>
              <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-cyan-500/20 to-blue-600/20 blur-2xl" aria-hidden="true"></div>

              <%# Profile image placeholder %>
              <% const heroImage = (settings && settings.hero_image) ? settings.hero_image : null; %>
              <% if (heroImage) { %>
              <img src="<%= heroImage %>" alt="Angga Dwy Saputra" loading="eager"
                   class="relative z-10 h-80 w-64 rounded-2xl object-cover object-top shadow-2xl sm:h-96 sm:w-72" />
              <% } else { %>
              <div class="relative z-10 flex h-80 w-64 items-center justify-center rounded-2xl bg-gradient-to-br from-zinc-800 to-zinc-900 shadow-2xl sm:h-96 sm:w-72" aria-label="Foto profil placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-32 w-32 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <% } %>

              <%# Availability badge %>
              <div class="absolute -bottom-4 left-1/2 z-20 -translate-x-1/2 whitespace-nowrap rounded-full border border-green-500/30 bg-zinc-900 px-4 py-2 text-xs font-semibold text-green-400 shadow-lg">
                <span class="mr-1.5 inline-block h-2 w-2 rounded-full bg-green-400"></span>
                Tersedia untuk proyek baru
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <%# SERVICES SECTION %>
    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <section class="bg-zinc-900/50 py-20 sm:py-24" aria-labelledby="services-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="mb-12 text-center">
          <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-cyan-400">Layanan Saya</p>
          <h2 id="services-heading" class="text-2xl font-bold text-white sm:text-3xl">
            Solusi Digital untuk Kebutuhan Anda
          </h2>
          <p class="mt-3 text-zinc-400">Memberikan layanan terbaik dengan teknologi terkini dan tepat waktu.</p>
        </div>

        <% if (services && services.length > 0) { %>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
          <% services.slice(0, 4).forEach(function(service) { %>
          <article class="group rounded-xl border border-zinc-800 bg-zinc-900 p-6 transition-all hover:border-cyan-500/40 hover:bg-zinc-800/80">
            <%# Icon %>
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-400 transition-colors group-hover:bg-cyan-500/20">
              <% if (service.icon_image) { %>
              <img src="<%= service.icon_image %>" alt="" class="h-6 w-6 object-contain" loading="lazy" aria-hidden="true" />
              <% } else { %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
              <% } %>
            </div>
            <h3 class="mb-2 text-base font-semibold text-white"><%= service.title %></h3>
            <% if (service.short_description) { %>
            <p class="mb-4 line-clamp-3 text-sm leading-relaxed text-zinc-400"><%= service.short_description %></p>
            <% } %>
            <a href="/services/<%= service.slug %>" class="inline-flex items-center gap-1 text-xs font-semibold text-cyan-400 transition-colors hover:text-cyan-300" aria-label="Selengkapnya tentang <%= service.title %>">
              Selengkapnya
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </article>
          <% }); %>
        </div>
        <% } else { %>
        <%# Placeholder services when DB is empty %>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
          <% [
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Web Development', desc: 'Membangun website modern dengan teknologi terkini, responsif, cepat, dan mudah dikelola.' },
            { icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', title: 'SEO Specialist', desc: 'Optimasi mesin pencari untuk meningkatkan visibilitas dan traffic organik website Anda.' },
            { icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18', title: 'IT Support', desc: 'Dukungan teknis IT untuk memastikan sistem dan infrastruktur digital Anda berjalan optimal.' },
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Website Maintenance', desc: 'Pemeliharaan rutin website termasuk update, backup, monitoring, dan perbaikan bug.' },
          ].forEach(function(s) { %>
          <article class="group rounded-xl border border-zinc-800 bg-zinc-900 p-6 transition-all hover:border-cyan-500/40 hover:bg-zinc-800/80">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="<%= s.icon %>"/></svg>
            </div>
            <h3 class="mb-2 text-base font-semibold text-white"><%= s.title %></h3>
            <p class="mb-4 text-sm leading-relaxed text-zinc-400"><%= s.desc %></p>
            <a href="/services" class="inline-flex items-center gap-1 text-xs font-semibold text-cyan-400 hover:text-cyan-300">
              Selengkapnya <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </article>
          <% }); %>
        </div>
        <% } %>

      </div>
    </section>

    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <%# PORTFOLIO SECTION %>
    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <section class="py-20 sm:py-24" aria-labelledby="portfolio-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="mb-10 flex items-end justify-between">
          <div>
            <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-cyan-400">Portfolio Terbaru</p>
            <h2 id="portfolio-heading" class="text-2xl font-bold text-white sm:text-3xl">Beberapa Hasil Karya Saya</h2>
            <p class="mt-2 text-zinc-400">Berikut proyek yang telah saya kerjakan untuk klien dan portofolio pribadi.</p>
          </div>
          <a href="/portfolio" class="hidden shrink-0 text-sm font-semibold text-cyan-400 transition-colors hover:text-cyan-300 sm:inline-flex sm:items-center sm:gap-1">
            Lihat Semua Portfolio
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <% if (portfolios && portfolios.length > 0) { %>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% portfolios.forEach(function(item) { %>
          <article class="group overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900 transition-all hover:border-zinc-700 hover:shadow-xl hover:shadow-black/30">
            <%# Thumbnail %>
            <a href="/portfolio/<%= item.slug %>" class="block overflow-hidden" tabindex="-1" aria-hidden="true">
              <% if (item.image) { %>
              <img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy"
                   class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105" />
              <% } else { %>
              <div class="flex h-44 w-full items-center justify-center bg-gradient-to-br from-zinc-800 to-zinc-900">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <% } %>
            </a>
            <div class="p-5">
              <% if (item.category) { %>
              <span class="mb-2 inline-block rounded-full bg-cyan-500/10 px-2.5 py-0.5 text-xs font-medium text-cyan-400"><%= item.category %></span>
              <% } %>
              <h3 class="mb-1.5 text-base font-semibold text-white">
                <a href="/portfolio/<%= item.slug %>" class="transition-colors hover:text-cyan-400"><%= item.title %></a>
              </h3>
              <% if (item.short_description) { %>
              <p class="mb-3 line-clamp-2 text-sm text-zinc-400"><%= item.short_description %></p>
              <% } %>
              <%# Tech stack badges %>
              <% if (item.tech_stack) { %>
              <div class="mb-4 flex flex-wrap gap-1.5" aria-label="Tech stack">
                <% let techs = []; try { techs = JSON.parse(item.tech_stack); } catch(e) { techs = item.tech_stack.split(',').map(function(t){ return t.trim(); }); } %>
                <% techs.slice(0, 4).forEach(function(t) { %>
                <span class="rounded bg-zinc-800 px-2 py-0.5 text-xs text-zinc-400"><%= t %></span>
                <% }); %>
              </div>
              <% } %>
              <%# Action links %>
              <div class="flex items-center gap-3">
                <a href="/portfolio/<%= item.slug %>" class="inline-flex items-center gap-1 text-xs font-semibold text-cyan-400 hover:text-cyan-300" aria-label="Detail <%= item.title %>">
                  Detail
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </a>
                <% if (item.demo_link) { %>
                <a href="<%= item.demo_link %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs text-zinc-500 hover:text-zinc-300" aria-label="Demo <%= item.title %>">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  Demo
                </a>
                <% } %>
                <% if (item.github_link) { %>
                <a href="<%= item.github_link %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs text-zinc-500 hover:text-zinc-300" aria-label="GitHub <%= item.title %>">
                  <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                  GitHub
                </a>
                <% } %>
              </div>
            </div>
          </article>
          <% }); %>
        </div>
        <% } else { %>
        <%# Placeholder portfolio cards %>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% [
            { title: 'Nexora Studio', cat: 'Web Development', desc: 'Website company profile modern dengan animasi halus dan performa tinggi.' },
            { title: 'Cafe Aroma', cat: 'Web Development', desc: 'Landing page kafe dengan sistem reservasi online dan menu digital.' },
            { title: 'TravelGo Indonesia', cat: 'SEO & Web', desc: 'Platform travel dengan optimasi SEO yang meningkatkan traffic 300%.' },
          ].forEach(function(p) { %>
          <article class="overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900">
            <div class="flex h-44 items-center justify-center bg-gradient-to-br from-zinc-800 to-zinc-900">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="p-5">
              <span class="mb-2 inline-block rounded-full bg-cyan-500/10 px-2.5 py-0.5 text-xs font-medium text-cyan-400"><%= p.cat %></span>
              <h3 class="mb-1.5 text-base font-semibold text-white"><%= p.title %></h3>
              <p class="mb-3 text-sm text-zinc-400"><%= p.desc %></p>
              <div class="flex gap-1.5">
                <span class="rounded bg-zinc-800 px-2 py-0.5 text-xs text-zinc-400">Node.js</span>
                <span class="rounded bg-zinc-800 px-2 py-0.5 text-xs text-zinc-400">TailwindCSS</span>
              </div>
            </div>
          </article>
          <% }); %>
        </div>
        <% } %>

        <div class="mt-8 text-center sm:hidden">
          <a href="/portfolio" class="inline-flex items-center gap-1 text-sm font-semibold text-cyan-400 hover:text-cyan-300">
            Lihat Semua Portfolio <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

      </div>
    </section>

    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <%# STATS + TESTIMONIAL SECTION %>
    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <section class="bg-zinc-900/60 py-16 sm:py-20" aria-label="Statistik dan testimoni">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-16">

          <%# Stats %>
          <div class="flex items-center justify-center gap-8 sm:gap-16">
            <% [
              { value: '20+', label: 'Proyek Selesai' },
              { value: '15+', label: 'Klien Puas' },
              { value: '99%', label: 'Tingkat Kepuasan' },
            ].forEach(function(stat) { %>
            <div class="text-center">
              <div class="text-3xl font-extrabold text-cyan-400 sm:text-4xl"><%= stat.value %></div>
              <div class="mt-1 text-xs text-zinc-400 sm:text-sm"><%= stat.label %></div>
            </div>
            <% }); %>
          </div>

          <%# Testimonial quote %>
          <blockquote class="flex flex-col justify-center rounded-xl border border-zinc-800 bg-zinc-900 p-6">
            <svg class="mb-4 h-8 w-8 text-cyan-500/40" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z"/>
            </svg>
            <p class="mb-4 text-sm leading-relaxed text-zinc-300 sm:text-base">
              "Ada yang yang yang baik, komunikasi lancar dan hasil memuaskan. Sangat direkomendasikan untuk kebutuhan website profesional Anda."
            </p>
            <footer class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-cyan-500 to-blue-600 text-sm font-bold text-white">R</div>
              <div>
                <div class="text-sm font-semibold text-white">Raka Pratama</div>
                <div class="text-xs text-zinc-500">CEO, Nexora Studio</div>
              </div>
              <div class="ml-auto flex gap-0.5" aria-label="Rating 5 bintang">
                <% for (var i = 0; i < 5; i++) { %>
                <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <% } %>
              </div>
            </footer>
          </blockquote>

        </div>
      </div>
    </section>

    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <%# BLOG SECTION %>
    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <section class="py-20 sm:py-24" aria-labelledby="blog-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="mb-10 flex items-end justify-between">
          <div>
            <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-cyan-400">Artikel Terbaru</p>
            <h2 id="blog-heading" class="text-2xl font-bold text-white sm:text-3xl">Artikel &amp; Tips Terbaru</h2>
            <p class="mt-2 text-zinc-400">Berbagi pengetahuan seputar web development, SEO dan teknologi.</p>
          </div>
          <a href="/blog" class="hidden shrink-0 text-sm font-semibold text-cyan-400 hover:text-cyan-300 sm:inline-flex sm:items-center sm:gap-1">
            Lihat Semua Artikel
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <% if (blogPosts && blogPosts.length > 0) { %>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% blogPosts.forEach(function(post) { %>
          <article class="group overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900 transition-all hover:border-zinc-700">
            <a href="/blog/<%= post.slug %>" class="block overflow-hidden" tabindex="-1" aria-hidden="true">
              <% if (post.featured_image) { %>
              <img src="<%= post.featured_image %>" alt="<%= post.title %>" loading="lazy"
                   class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105" />
              <% } else { %>
              <div class="flex h-44 items-center justify-center bg-gradient-to-br from-zinc-800 to-zinc-900">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
              </div>
              <% } %>
            </a>
            <div class="p-5">
              <div class="mb-2 flex items-center gap-2 text-xs text-zinc-500">
                <span class="rounded-full bg-cyan-500/10 px-2.5 py-0.5 font-medium text-cyan-400">Blog</span>
                <% if (post.published_at) { %>
                <time datetime="<%= new Date(post.published_at).toISOString() %>">
                  <%= new Date(post.published_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                </time>
                <% } %>
              </div>
              <h3 class="mb-2 text-base font-semibold leading-snug text-white">
                <a href="/blog/<%= post.slug %>" class="transition-colors hover:text-cyan-400"><%= post.title %></a>
              </h3>
              <% if (post.excerpt) { %>
              <p class="mb-4 line-clamp-2 text-sm text-zinc-400"><%= post.excerpt %></p>
              <% } %>
              <a href="/blog/<%= post.slug %>" class="inline-flex items-center gap-1 text-xs font-semibold text-cyan-400 hover:text-cyan-300" aria-label="Baca selengkapnya: <%= post.title %>">
                Baca Selengkapnya
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
          <% }); %>
        </div>
        <% } else { %>
        <%# Placeholder blog cards %>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% [
            { title: 'Cara Membuat Website Cepat dan SEO Friendly', cat: 'SEO', date: '15 Jan 2025', desc: 'Panduan lengkap membuat website yang cepat dimuat dan mudah ditemukan di Google.' },
            { title: 'SEO On-Page Checklist 2024', cat: 'SEO', date: '10 Jan 2025', desc: 'Daftar lengkap optimasi on-page yang wajib dilakukan untuk setiap halaman website.' },
            { title: '5 Tools Wajib Untuk Web Developer', cat: 'Dev', date: '5 Jan 2025', desc: 'Tools yang akan meningkatkan produktivitas dan kualitas kode Anda sebagai developer.' },
          ].forEach(function(p) { %>
          <article class="overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900">
            <div class="flex h-44 items-center justify-center bg-gradient-to-br from-zinc-800 to-zinc-900">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
            <div class="p-5">
              <div class="mb-2 flex items-center gap-2 text-xs text-zinc-500">
                <span class="rounded-full bg-cyan-500/10 px-2.5 py-0.5 font-medium text-cyan-400"><%= p.cat %></span>
                <span><%= p.date %></span>
              </div>
              <h3 class="mb-2 text-base font-semibold leading-snug text-white"><%= p.title %></h3>
              <p class="mb-4 text-sm text-zinc-400"><%= p.desc %></p>
              <a href="/blog" class="inline-flex items-center gap-1 text-xs font-semibold text-cyan-400 hover:text-cyan-300">
                Baca Selengkapnya <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
          <% }); %>
        </div>
        <% } %>

      </div>
    </section>

    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <%# CTA SECTION %>
    <%# ═══════════════════════════════════════════════════════════════════════ %>
    <section class="bg-zinc-900/80 py-16 sm:py-20" aria-labelledby="cta-heading">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">

          <%# Left: CTA text + contact info %>
          <div>
            <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-cyan-400">Hubungi Saya</p>
            <h2 id="cta-heading" class="mb-4 text-2xl font-bold text-white sm:text-3xl">
              Mari Wujudkan Ide Anda
            </h2>
            <p class="mb-8 text-zinc-400">
              Hubungi saya untuk mendiskusikan kebutuhan website atau SEO Anda. Saya siap membantu mewujudkan proyek impian Anda.
            </p>

            <a href="/contact" class="mb-8 inline-flex items-center gap-2 rounded-lg bg-cyan-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-cyan-500/25 transition-all hover:bg-cyan-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400">
              Hubungi Saya Sekarang
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>

            <ul class="mt-6 space-y-3">
              <% const ctaEmail = (settings && settings.contact_email) ? settings.contact_email : 'hello@artupski.com'; %>
              <% const ctaWa    = (settings && settings.whatsapp_number) ? settings.whatsapp_number : '+62 812-3456-7890'; %>
              <% const ctaAddr  = (settings && settings.address) ? settings.address : 'Indonesia'; %>
              <li class="flex items-center gap-3 text-sm text-zinc-400">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-zinc-800 text-cyan-400" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <a href="mailto:<%= ctaEmail %>" class="hover:text-cyan-400"><%= ctaEmail %></a>
              </li>
              <li class="flex items-center gap-3 text-sm text-zinc-400">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-zinc-800 text-cyan-400" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <a href="https://wa.me/<%= ctaWa.replace(/\D/g,'') %>" target="_blank" rel="noopener noreferrer" class="hover:text-cyan-400"><%= ctaWa %></a>
              </li>
              <li class="flex items-center gap-3 text-sm text-zinc-400">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-zinc-800 text-cyan-400" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span><%= ctaAddr %></span>
              </li>
            </ul>
          </div>

          <%# Right: laptop illustration placeholder %>
          <div class="flex justify-center lg:justify-end">
            <div class="relative flex h-64 w-full max-w-sm items-center justify-center rounded-2xl border border-zinc-800 bg-gradient-to-br from-zinc-900 to-zinc-800 sm:h-72">
              <%# Decorative glow %>
              <div class="absolute inset-0 rounded-2xl bg-cyan-500/5" aria-hidden="true"></div>
              <%# Laptop icon placeholder %>
              <div class="relative text-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-3 h-24 w-24 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div class="text-3xl font-black text-cyan-400">AD</div>
                <div class="mt-1 text-xs text-zinc-500">Angga Dwy Saputra</div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <%- include('../partials/footer', { settings: settings, socialLinks: socialLinks || [] }) %>
  <%- include('../partials/scripts') %>
</body>
</html>
