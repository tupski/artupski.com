<%#
  partials/footer.ejs — Public site footer (4-column dark design)
%>
<% const siteName     = (settings && settings.site_name)       ? settings.site_name       : 'Angga Dwy Saputra'; %>
<% const tagline      = (settings && settings.tagline)         ? settings.tagline         : 'Web Developer & SEO Specialist'; %>
<% const footerText   = (settings && settings.footer_text)     ? settings.footer_text     : null; %>
<% const contactEmail = (settings && settings.contact_email)   ? settings.contact_email   : null; %>
<% const whatsapp     = (settings && settings.whatsapp_number) ? settings.whatsapp_number : null; %>
<% const links        = (typeof socialLinks !== 'undefined' && Array.isArray(socialLinks)) ? socialLinks : []; %>
<% const currentYear  = new Date().getFullYear(); %>

<footer class="border-t border-zinc-800 bg-zinc-950">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <%# ── Col 1: Brand ──────────────────────────────────────────────────── %>
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="mb-3 inline-block text-lg font-bold text-white hover:text-cyan-400">
          <span class="text-cyan-400">&lt;</span><%= siteName.split(' ')[0] %><span class="text-cyan-400">/&gt;</span>
        </a>
        <p class="mb-1 text-sm font-medium text-zinc-300"><%= siteName %></p>
        <p class="mb-4 text-xs text-zinc-500"><%= tagline %></p>
        <% if (footerText) { %>
        <p class="mb-4 text-xs leading-relaxed text-zinc-500"><%- footerText %></p>
        <% } else { %>
        <p class="mb-4 text-xs leading-relaxed text-zinc-500">
          Web Developer, SEO Specialist &amp; IT Support. Membantu bisnis berkembang di era digital.
        </p>
        <% } %>
        <%# Social icons %>
        <% if (links.length > 0) { %>
        <ul class="flex gap-2" role="list">
          <% links.forEach(function(link) { %>
          <li>
            <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" aria-label="<%= link.platform %>"
               class="flex h-8 w-8 items-center justify-center rounded-lg border border-zinc-800 text-zinc-500 transition-colors hover:border-cyan-500/50 hover:text-cyan-400">
              <% if (link.icon) { %>
              <i class="<%= link.icon %> text-xs" aria-hidden="true"></i>
              <% } else { %>
              <span class="text-xs font-bold"><%= link.platform.charAt(0) %></span>
              <% } %>
            </a>
          </li>
          <% }); %>
        </ul>
        <% } else { %>
        <%# Placeholder social icons %>
        <ul class="flex gap-2" role="list">
          <% [
            { label: 'GitHub',    path: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z' },
            { label: 'LinkedIn',  path: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z' },
            { label: 'Instagram', path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z' },
            { label: 'WhatsApp',  path: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z' },
          ].forEach(function(s) { %>
          <li>
            <a href="#" aria-label="<%= s.label %>"
               class="flex h-8 w-8 items-center justify-center rounded-lg border border-zinc-800 text-zinc-500 transition-colors hover:border-cyan-500/50 hover:text-cyan-400">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="<%= s.path %>"/></svg>
            </a>
          </li>
          <% }); %>
        </ul>
        <% } %>
      </div>

      <%# ── Col 2: Navigasi ────────────────────────────────────────────────── %>
      <div>
        <h3 class="mb-4 text-sm font-semibold text-white">Navigasi</h3>
        <ul class="space-y-2.5 text-sm text-zinc-500">
          <% [
            { href: '/',          label: 'Beranda' },
            { href: '/about',     label: 'Tentang' },
            { href: '/portfolio', label: 'Portfolio' },
            { href: '/services',  label: 'Layanan' },
            { href: '/blog',      label: 'Blog' },
            { href: '/contact',   label: 'Kontak' },
          ].forEach(function(link) { %>
          <li><a href="<%= link.href %>" class="transition-colors hover:text-cyan-400"><%= link.label %></a></li>
          <% }); %>
        </ul>
      </div>

      <%# ── Col 3: Layanan ─────────────────────────────────────────────────── %>
      <div>
        <h3 class="mb-4 text-sm font-semibold text-white">Layanan</h3>
        <ul class="space-y-2.5 text-sm text-zinc-500">
          <% [
            'Web Development',
            'SEO Specialist',
            'IT Support',
            'Website Maintenance',
            'Landing Page',
            'Company Profile',
          ].forEach(function(s) { %>
          <li><a href="/services" class="transition-colors hover:text-cyan-400"><%= s %></a></li>
          <% }); %>
        </ul>
      </div>

      <%# ── Col 4: Newsletter ──────────────────────────────────────────────── %>
      <div>
        <h3 class="mb-4 text-sm font-semibold text-white">Newsletter</h3>
        <p class="mb-4 text-xs leading-relaxed text-zinc-500">
          Dapatkan tips dan update terbaru, langsung di email Anda.
        </p>
        <form action="/contact" method="GET" class="flex gap-2" aria-label="Subscribe newsletter">
          <label for="newsletter-email" class="sr-only">Alamat email</label>
          <input
            type="email"
            id="newsletter-email"
            name="email"
            placeholder="Email Anda"
            class="min-w-0 flex-1 rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-xs text-zinc-300 placeholder-zinc-600 focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500"
          />
          <button type="submit" class="rounded-lg bg-cyan-500 px-3 py-2 text-xs font-semibold text-white transition-colors hover:bg-cyan-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400">
            Subscribe
          </button>
        </form>
        <% if (contactEmail) { %>
        <p class="mt-4 text-xs text-zinc-600">
          Atau email langsung ke <a href="mailto:<%= contactEmail %>" class="text-zinc-500 hover:text-cyan-400"><%= contactEmail %></a>
        </p>
        <% } %>
      </div>

    </div>

    <%# ── Bottom bar ─────────────────────────────────────────────────────── %>
    <div class="mt-10 border-t border-zinc-800 pt-6">
      <p class="text-center text-xs text-zinc-600">
        &copy; <%= currentYear %> <%= siteName %>. All rights reserved.
      </p>
    </div>

  </div>
</footer>
