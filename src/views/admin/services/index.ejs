<%#
  admin/services/index.ejs — Services list
  ============================================================
  Variables expected:
    - pageTitle      {string}  'Services'
    - activePage     {string}  'services'
    - settings       {object}  res.locals.settings
    - unreadCount    {number}  Unread messages count
    - services       {Array}   All service rows (sorted by sort_order ASC)
    - successMessage {string|null}
    - errorMessage   {string|null}
  ============================================================
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('../../partials/head', {
    seo: { metaTitle: 'Services — Admin' },
    settings: settings,
    isAdmin: true
  }) %>
</head>
<body class="antialiased">

  <%- include('../../partials/sidebar', {
    settings:    settings,
    unreadCount: unreadCount || 0,
    activePage:  'services'
  }) %>

  <div class="page-wrapper">

    <%# ── Page Header ──────────────────────────────────────────────────────── %>
    <div class="page-header d-print-none">
      <div class="container-xl">
        <div class="row g-2 align-items-center">
          <div class="col">
            <h2 class="page-title">Services</h2>
            <div class="text-muted mt-1">Kelola layanan yang ditampilkan di website.</div>
          </div>
          <div class="col-auto ms-auto d-print-none">
            <div class="d-flex align-items-center gap-2">
              <a href="/" target="_blank" rel="noopener noreferrer"
                 class="btn btn-outline-secondary btn-sm d-none d-sm-inline-flex align-items-center gap-1"
                 aria-label="View public website">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24"
                     stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 6h-6a2 2 0 0 0 -2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-6" />
                  <path d="M11 13l9 -9" /><path d="M15 4h5v5" />
                </svg>
                View Site
              </a>
              <button id="theme-toggle" type="button" aria-label="Toggle dark/light mode"
                      class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center"
                      style="width:2.25rem;height:2.25rem;padding:0;">
                <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="icon icon-sm d-none" width="16" height="16"
                     viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" />
                  <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7" />
                </svg>
                <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16"
                     viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" />
                </svg>
              </button>
              <a href="/admin/services/create" class="btn btn-primary d-inline-flex align-items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="16" height="16" viewBox="0 0 24 24"
                     stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 5l0 14" /><path d="M5 12l14 0" />
                </svg>
                Tambah Service
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# ── Page Body ─────────────────────────────────────────────────────────── %>
    <div class="page-body">
      <div class="container-xl">

        <%- include('../../partials/alerts', {
          successMessage: successMessage,
          errorMessage:   errorMessage,
          infoMessage:    null
        }) %>

        <div class="card">
          <div class="card-header d-flex align-items-center justify-content-between">
            <h3 class="card-title mb-0">Daftar Services</h3>
            <span class="text-muted small"><%= services.length %> service</span>
          </div>

          <div class="table-responsive">
            <table class="table table-vcenter card-table">
              <thead>
                <tr>
                  <th style="width:60px;">Icon</th>
                  <th>Judul</th>
                  <th class="d-none d-md-table-cell">Slug</th>
                  <th class="d-none d-lg-table-cell">Harga</th>
                  <th style="width:80px;">Urutan</th>
                  <th style="width:100px;">Status</th>
                  <th style="width:120px;">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% if (services && services.length > 0) { %>
                  <% services.forEach(function(service) { %>
                    <tr>
                      <td>
                        <% if (service.icon_image) { %>
                          <img
                            src="<%= service.icon_image %>"
                            alt="Icon <%= service.title %>"
                            loading="lazy"
                            class="rounded"
                            style="width:40px;height:40px;object-fit:cover;"
                          />
                        <% } else { %>
                          <div class="avatar avatar-sm bg-secondary-lt rounded d-flex align-items-center justify-content-center"
                               style="width:40px;height:40px;" aria-label="No icon">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon text-muted" width="20" height="20"
                                 viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M12 3l8 4.5l0 9l-8 4.5l-8 -4.5l0 -9l8 -4.5" />
                            </svg>
                          </div>
                        <% } %>
                      </td>
                      <td>
                        <div class="fw-medium"><%= service.title %></div>
                        <% if (service.short_description) { %>
                          <div class="text-muted small text-truncate" style="max-width:260px;">
                            <%= service.short_description %>
                          </div>
                        <% } %>
                      </td>
                      <td class="d-none d-md-table-cell">
                        <code class="text-muted small"><%= service.slug %></code>
                      </td>
                      <td class="d-none d-lg-table-cell">
                        <% if (service.price_label) { %>
                          <span class="text-body"><%= service.price_label %></span>
                        <% } else { %>
                          <span class="text-muted">—</span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <span class="text-muted"><%= service.sort_order || 0 %></span>
                      </td>
                      <td>
                        <span class="badge <%= service.status === 'active' ? 'bg-success' : 'bg-secondary' %>">
                          <%= service.status === 'active' ? 'Active' : 'Inactive' %>
                        </span>
                      </td>
                      <td>
                        <div class="d-flex gap-1">
                          <a href="/admin/services/<%= service.id %>/edit"
                             class="btn btn-sm btn-outline-primary"
                             aria-label="Edit <%= service.title %>">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="14" height="14"
                                 viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" />
                              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z" />
                            </svg>
                            Edit
                          </a>
                          <form
                            action="/admin/services/<%= service.id %>?_method=DELETE"
                            method="POST"
                            onsubmit="return confirm('Hapus service \"<%= service.title.replace(/'/g, '\\\'') %>\"? Tindakan ini tidak dapat dibatalkan.')"
                          >
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    aria-label="Hapus <%= service.title %>">
                              <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="14" height="14"
                                   viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"
                                   stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M4 7l16 0" /><path d="M10 11l0 6" /><path d="M14 11l0 6" />
                                <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                                <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
                              </svg>
                              Hapus
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                      Belum ada service. <a href="/admin/services/create">Tambah service pertama</a>.
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>

    <%# ── Footer ─────────────────────────────────────────────────────────── %>
    <footer class="footer footer-transparent d-print-none">
      <div class="container-xl">
        <div class="row text-center align-items-center flex-row-reverse">
          <div class="col-lg-auto ms-lg-auto">
            <ul class="list-inline list-inline-dots mb-0">
              <li class="list-inline-item"><a href="/" target="_blank" rel="noopener noreferrer" class="link-secondary">View Site</a></li>
              <li class="list-inline-item"><a href="/admin/settings" class="link-secondary">Settings</a></li>
            </ul>
          </div>
          <div class="col-12 col-lg-auto mt-3 mt-lg-0">
            <ul class="list-inline list-inline-dots mb-0">
              <li class="list-inline-item">
                &copy; <%= new Date().getFullYear() %>
                <a href="/" class="link-secondary"><%= (settings && settings.site_name) ? settings.site_name : 'Artupski' %></a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

  </div><%# end .page-wrapper %>

  <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/js/tabler.min.js"></script>
  <script src="/js/admin.js"></script>
  <script>
    (function () {
      var btn  = document.getElementById('theme-toggle');
      var sun  = document.getElementById('icon-sun');
      var moon = document.getElementById('icon-moon');
      function syncIcons() {
        var isDark = document.documentElement.classList.contains('dark');
        if (sun)  sun.classList.toggle('d-none', !isDark);
        if (moon) moon.classList.toggle('d-none', isDark);
      }
      syncIcons();
      if (btn) {
        btn.addEventListener('click', function () {
          if (typeof toggleTheme === 'function') { toggleTheme(); }
          else {
            var isDark = document.documentElement.classList.contains('dark');
            document.documentElement.classList.toggle('dark', !isDark);
            try { localStorage.setItem('theme', isDark ? 'light' : 'dark'); } catch (e) {}
          }
          syncIcons();
        });
      }
    })();
  </script>

</body>
</html>
